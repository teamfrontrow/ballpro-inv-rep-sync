      // Load sales tools content
      function loadSalesToolsContent() {
        const salesToolsContent = document.getElementById('salesToolsContent');
        if (!salesToolsContent) return;

        // Get product title and SKU
        const productTitle = document.querySelector('h1.product__title')?.textContent?.trim() || 
                           '{{ product.title | escape }}';
        const productSKU = getCurrentVariantSKU() || '{{ product.selected_or_first_available_variant.sku }}';
        
        // Update product display
        const salesToolsDisplayElement = document.getElementById('sales-tools-product-display');
        if (salesToolsDisplayElement) {
          const displayText = productSKU ? `# ${productSKU} - ${productTitle}` : productTitle;
          salesToolsDisplayElement.textContent = displayText;
        }
        
        // Check if product title contains "Golf Balls" and does not contain "Wilson 50" or "Wilson Duo Soft"
        // OR contains "Callaway Dozen box" OR contains "Dozen Titleist"
        const containsGolfBalls = productTitle.toLowerCase().includes('golf balls');
        const containsWilson50 = productTitle.toLowerCase().includes('wilson 50');
        const containsWilsonDuoSoft = productTitle.toLowerCase().includes('wilson duo soft');
        const containsCallawayDozenBox = productTitle.toLowerCase().includes('callaway dozen box');
        const containsDozenTitleist = productTitle.toLowerCase().includes('dozen titleist');
        
        // Check if product title contains "Baseball" and does NOT contain "Keychain" or "Acrylic" or "Bat" or "Cooler" or "Synthetic"
        const containsBaseball = productTitle.toLowerCase().includes('baseball');
        const containsKeychain = productTitle.toLowerCase().includes('keychain');
        const containsAcrylic = productTitle.toLowerCase().includes('acrylic');
        const containsBat = productTitle.toLowerCase().includes('bat');
        const containsCooler = productTitle.toLowerCase().includes('cooler');
        const containsSynthetic = productTitle.toLowerCase().includes('synthetic');
        const showBaseballTemplate = containsBaseball && !containsKeychain && !containsAcrylic && !containsBat && !containsCooler && !containsSynthetic;
        
        let html = '<div style="margin-top: 20px;">';
        html += '<div style="border: 1px solid rgba(var(--color-foreground), 0.1); border-radius: 4px; padding: 20px; background-color: rgba(var(--color-background), 1);">';
        html += '<h3 style="margin-bottom: 15px; font-size: 1.8rem;">Artwork Templates</h3>';
        html += '<p style="margin-bottom: 15px; color: rgba(var(--color-foreground), 0.8); font-size: 1.5rem;">Templates for artwork layout and margin information.</p>';
        
        let templateShown = false;
        
        // Check for Golf Ball template
        if ((containsGolfBalls && !containsWilson50 && !containsWilsonDuoSoft) || containsCallawayDozenBox || containsDozenTitleist) {
          // Show the Template link
          html += '<p style="margin-bottom: 10px;"><a href="https://s3.distributorcentral.com/uploads/6/E/6EA141D552BAB890BA6B424986067D97.pdf" target="_blank" style="color: rgba(var(--color-foreground), 1); text-decoration: underline; font-size: 1.6rem;">View Golf Ball Template</a></p>';
          templateShown = true;
        }
        
        // Check for Baseball template
        if (showBaseballTemplate) {
          html += '<p style="margin-bottom: 10px;"><a href="https://s3.distributorcentral.com/uploads/0/C/0C560CA6CD4EFCAAA0BC14E6970CDE38.pdf" target="_blank" style="color: rgba(var(--color-foreground), 1); text-decoration: underline; font-size: 1.6rem;">Template</a></p>';
          templateShown = true;
        }
        
        // Show message if no template is available
        if (!templateShown) {
          html += '<p style="margin-bottom: 10px; color: rgba(var(--color-foreground), 0.6); font-size: 1.5rem;">Template not available for this product.</p>';
        }
        
        html += '</div>';
        html += '</div>';
        salesToolsContent.innerHTML = html;
      }

      // Load product options content
      function loadProductOptionsContent() {
        const productOptionsContent = document.getElementById('productOptionsContent');
        if (!productOptionsContent) return;

        // Get product title and SKU
        const productTitle = document.querySelector('h1.product__title')?.textContent?.trim() || 
                           '{{ product.title | escape }}';
        const productSKU = getCurrentVariantSKU() || '{{ product.selected_or_first_available_variant.sku }}';
        
        // Update product display
        const productOptionsDisplayElement = document.getElementById('product-options-product-display');
        if (productOptionsDisplayElement) {
          const displayText = productSKU ? `# ${productSKU} - ${productTitle}` : productTitle;
          productOptionsDisplayElement.textContent = displayText;
        }

        // Get product data to access metafields
        const productData = getProductData();
        let html = '';

        // Container 1: PMS Charge
        {% if product.metafields.custom.pms_charges.value %}
        const pmsCharges = '{{ product.metafields.custom.pms_charges.value | escape }}';
        {% else %}
        const pmsCharges = productData?.metafields?.custom?.pms_charges?.value || '';
        {% endif %}
        if (pmsCharges && pmsCharges !== '') {
          html += '<div class="product-options-container">';
          html += '<h3>PMS Charge</h3>';
          
          // Parse: "$45(V) Per color" -> "Price: $45.00 per color"
          const pmsMatch = pmsCharges.match(/\$([\d.]+)\(V\)\s*(.+)/i);
          if (pmsMatch) {
            const price = parseFloat(pmsMatch[1]).toFixed(2);
            const unit = pmsMatch[2].trim().toLowerCase();
            html += `<p>Price: $${price} ${unit}</p>`;
          } else {
            html += `<p>${pmsCharges}</p>`;
          }
          
          html += '</div>';
        }

        // Container 2: 2nd Color Run Charge OR 2nd Pole Golf Balls
        {% if product.metafields.custom.addition_imprint_charges.value %}
        const additionImprintCharges = '{{ product.metafields.custom.addition_imprint_charges.value | escape }}';
        {% else %}
        const additionImprintCharges = productData?.metafields?.custom?.addition_imprint_charges?.value || '';
        {% endif %}
        if (additionImprintCharges && additionImprintCharges !== '') {
          const chargesStr = String(additionImprintCharges);
          
          // Check if it contains "Per color" (Option 1) or "2nd Pole Imprint" (Option 2)
          if (chargesStr.toLowerCase().includes('per color')) {
            // Option 1: 2nd Color Run Charge
            html += '<div class="product-options-container">';
            html += '<h3>2nd Color Run Charge</h3>';
            
            // Parse: "$0.40(V) Per color/per pc $50(V) Setup charge per color"
            // Extract price: $0.40(V) Per color/per pc
            const priceMatch = chargesStr.match(/\$([\d.]+)\(V\)\s*Per\s+color/i);
            // Extract setup charge: $50(V) Setup charge per color
            const setupMatch = chargesStr.match(/\$([\d.]+)\(V\)\s*Setup\s+charge/i);
            
            if (priceMatch) {
              const price = parseFloat(priceMatch[1]).toFixed(2);
              html += `<p>Price: $${price} each</p>`;
            }
            
            if (setupMatch) {
              const setupPrice = parseFloat(setupMatch[1]).toFixed(2);
              html += `<p>Setup Charge: $${setupPrice} each</p>`;
            }
            
            html += '</div>';
          } else if (chargesStr.toLowerCase().includes('2nd pole imprint')) {
            // Option 2: 2nd Pole Golf Balls
            html += '<div class="product-options-container">';
            html += '<h3>2nd Pole Golf Balls</h3>';
            
            // Parse: "2nd Pole Imprint $3.75(V) Per Dozen $50{V) Setup charge per location"
            // Handle both (V) and {V) variations - match $digits followed by either (V) or {V)
            const priceMatch = chargesStr.match(/\$([\d.]+)(\(|\{)V\)\s*Per\s+Dozen/i);
            // Match both (V) and {V) for setup charge
            const setupMatch = chargesStr.match(/\$([\d.]+)(\(|\{)V\)\s*Setup\s+charge/i);
            
            if (priceMatch) {
              const price = parseFloat(priceMatch[1]).toFixed(2);
              html += `<p>Price: $${price} per dozen</p>`;
            }
            
            if (setupMatch) {
              const setupPrice = parseFloat(setupMatch[1]).toFixed(2);
              html += `<p>Setup Charge: $${setupPrice} each</p>`;
            }
            
            html += '</div>';
          } else {
            // Option 3: 2nd Location Run Charge (if metafield exists but doesn't match Option 1 or Option 2)
            html += '<div class="product-options-container">';
            html += '<h3>2nd Location Run Charge</h3>';
            
            // Parse: "$0.35(V) Per location/per pc $50(V) Setup charge per location"
            // Extract price: $0.35(V) Per location/per pc
            const priceMatch = chargesStr.match(/\$([\d.]+)\(V\)\s*Per\s+location/i);
            // Extract setup charge: $50(V) Setup charge per location
            const setupMatch = chargesStr.match(/\$([\d.]+)\(V\)\s*Setup\s+charge\s+per\s+location/i);
            
            if (priceMatch) {
              const price = parseFloat(priceMatch[1]).toFixed(2);
              html += `<p>Price: $${price} each</p>`;
            }
            
            if (setupMatch) {
              const setupPrice = parseFloat(setupMatch[1]).toFixed(2);
              html += `<p>Setup Charge: $${setupPrice} per location</p>`;
            }
            
            html += '</div>';
          }
        }

        // Container 3: FCD Upgrade Charge
        {% if product.metafields.custom.imprint_method_charge.value %}
        const imprintMethodCharge = '{{ product.metafields.custom.imprint_method_charge.value | escape }}';
        {% else %}
        const imprintMethodCharge = productData?.metafields?.custom?.imprint_method_charge?.value || '';
        {% endif %}
        if (imprintMethodCharge && imprintMethodCharge !== '') {
          html += '<div class="product-options-container">';
          html += '<h3>FCD Upgrade Charge</h3>';
          
          // Parse: "Full color transfer - $.65(V) Per pc; $62.50(V) Setup charge"
          const chargeStr = String(imprintMethodCharge);
          
          // Extract price: $.65(V) Per pc
          const priceMatch = chargeStr.match(/\$([\d.]+)\(V\)\s*Per\s+pc/i);
          // Extract setup charge: $62.50(V) Setup charge
          const setupMatch = chargeStr.match(/\$([\d.]+)\(V\)\s*Setup\s+charge/i);
          
          if (priceMatch) {
            const price = parseFloat(priceMatch[1]).toFixed(2);
            html += `<p>Price: $${price} each</p>`;
          }
          
          if (setupMatch) {
            const setupPrice = parseFloat(setupMatch[1]).toFixed(2);
            html += `<p>Setup Charge: $${setupPrice} each</p>`;
          }
          
          html += '</div>';
        }

        // If no containers were added, show a message
        if (html === '') {
          html = '<p>No product options available for this product.</p>';
        }

        productOptionsContent.innerHTML = html;
      }

      // Handle form submissions
      function initializeForms() {
        // Email Product Form
        const emailForm = document.getElementById('emailProductForm');
        if (emailForm && !emailForm.dataset.initialized) {
          emailForm.dataset.initialized = 'true';
          emailForm.addEventListener('submit', function(e) {
      e.preventDefault();
            if (typeof emailjs === 'undefined') {
              alert('EmailJS is not loaded. Please check your connection.');
              return;
            }
            
            // Get form values
            const formData = new FormData(this);
            const recipientEmail = formData.get('to');
            
            // Validate recipient email first
            if (!recipientEmail || recipientEmail.trim() === '') {
              alert('Please enter a recipient email address.');
              return;
            }
            
            // Map form fields to template parameters
            // Try common EmailJS template variable names for recipient
            const templateParams = {
              to: recipientEmail,
              to_email: recipientEmail,
              recipient_email: recipientEmail,
              email_to: recipientEmail,
              from_email: formData.get('from_email'),
              from_name: formData.get('from_name') || '',
              subject: formData.get('subject'),
              message: formData.get('message') || '',
              product_title: formData.get('product_title'),
              product_sku: formData.get('product_sku'),
              product_url: formData.get('product_url'),
              send_copy: formData.get('send_copy'),
              copy_email: formData.get('copy_email') || ''
            };
            
      emailjs.send("service_mj8zxbu", "template_9ckncc7", templateParams)
        .then(function() {
          alert("Email sent successfully!");
                closeModal('emailProductModal');
                emailForm.reset();
        }, function(error) {
          alert("Failed to send email: " + JSON.stringify(error));
                console.error('EmailJS error:', error);
              });
          });
        }

        // Request Info Form
        const requestForm = document.getElementById('requestInfoForm');
        if (requestForm && !requestForm.dataset.initialized) {
          requestForm.dataset.initialized = 'true';
          requestForm.addEventListener('submit', function(e) {
          e.preventDefault();
            if (typeof emailjs === 'undefined') {
              alert('EmailJS is not loaded. Please check your connection.');
              return;
            }

          emailjs.sendForm("service_mj8zxbu", "template_soo5ntm", this)
            .then(() => {
              alert("Request sent successfully!");
                closeModal('requestInfoModal');
                requestForm.reset();
            })
            .catch((err) => {
              alert("Error sending request. Please try again.");
                console.error('EmailJS error:', err);
            });
        });
        }
      }

      // Initialize on DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeForms);
      } else {
        initializeForms();
      }

      // Re-initialize forms when product info updates (for dynamic content)
      const productInfo = document.querySelector('product-info');
      if (productInfo) {
        const observer = new MutationObserver(function(mutations) {
          initializeForms();
        });
        observer.observe(productInfo, { childList: true, subtree: true });
      }
    })();
    </script>
