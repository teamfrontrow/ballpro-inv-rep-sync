  {%- if template.name == 'product' -%}
    <style>
      .product__popup-page-title {
        margin-bottom: 0px!important;
      }
      .product__popup-form {
        padding: 0px;
      }
      .product__popup-form .form-group {
        margin-bottom: 0px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
      }
      .product__popup-form .form-row {
        display: grid;
        gap: 20px;
        margin-bottom: 0px;
        width: 100%;
      }
      .product__popup-form .form-row--two {
        grid-template-columns: 1fr 1fr;
      }
      .product__popup-form .form-row--three {
        grid-template-columns: 1fr 1fr 1fr;
      }
      @media (max-width: 768px) {
        .product__popup-form .form-row--two,
        .product__popup-form .form-row--three {
          grid-template-columns: 1fr;
        }
      }
      .product__popup-form label {
        display: block !important;
        margin-top: 10px;
        font-weight: 600;
        color: inherit;
        width: 100%;
        text-align: left;
        padding: 0;
        margin-left: 0;
      }
      .product__popup-form .form-group > label {
        display: block !important;
        flex-shrink: 0;
        width: 100%;
      }
      .product__popup-form .form-group > .form-control,
      .product__popup-form .form-group > textarea {
        display: block !important;
        width: 100%;
        flex: 1;
        margin-left: 0;
        padding-left: 12px;
        padding-right: 12px;
      }
      .product__popup-form .form-control {
        width: 100%;
        padding: 0;
        border: 1px solid rgba(var(--color-foreground), 0.2);
        border-radius: 4px;
        font-size: 1.5rem !important;
        font-family: inherit;
        background: rgba(var(--color-background), 1);
        color: rgba(var(--color-foreground), 1);
        box-sizing: border-box;
        height: auto;
        line-height: 1.5;
        margin: 0;
      }
      .product__popup-form input[type="text"],
      .product__popup-form input[type="email"],
      .product__popup-form input[type="tel"],
      .product__popup-form input[type="text"].form-control,
      .product__popup-form input[type="email"].form-control,
      .product__popup-form input[type="tel"].form-control {
        padding: 8px 12px;
        height: auto;
        min-height: 36px;
        font-size: 1.5rem !important;
        line-height: 1.5;
      }
      .product__popup-form .form-control:focus {
        outline: 2px solid rgba(var(--color-foreground), 0.5);
        outline-offset: 2px;
      }
      .product__popup-form textarea.form-control {
        resize: vertical;
        min-height: 60px;
        max-height: 120px;
        padding: 8px 12px;
        height: 60px;
        font-size: 1.5rem !important;
        line-height: 1.5;
      }
      .product__popup-form input[type="checkbox"] {
        width: 18px;
        height: 18px;
        min-width: 18px;
        min-height: 18px;
        margin: 0 8px 0 0;
        cursor: pointer;
        accent-color: rgba(var(--color-foreground), 1);
        flex-shrink: 0;
      }
      .product__popup-form input[type="checkbox"]:checked {
        background-color: rgba(var(--color-foreground), 1);
      }
      .inventory-table {
        margin-top: 20px;
      }
      .inventory-table th {
        font-weight: 600;
        text-align: left;
      }
      .inventory-table td,
      .inventory-table th {
        padding: 12px;
        border: 1px solid rgba(var(--color-foreground), 0.1);
      }
      .inventory-table tbody tr:hover {
        background-color: rgba(var(--color-foreground), 0.05);
      }
      .showInventory, .salesTools, .showProductOptions {
        text-decoration: inherit;
        background-color: #fff;
        color: #000;
        border-radius: 30px;
        padding: 10px;
        flex: 1;
        min-width: 0;
        text-align: center;
        border: 1px solid #000;
      }
      .showInventory:hover, .salesTools:hover, .showProductOptions:hover {
        background-color: #000;
        color: #fff;
        transition: 0.4s;
        border: 1px solid #000;
      }
      .product-options-container {
        border: 1px solid rgba(var(--color-foreground), 0.1);
        border-radius: 4px;
        padding: 20px;
        margin-bottom: 20px;
        background-color: rgba(var(--color-background), 1);
      }
      .product-options-container h3 {
        margin-bottom: 15px;
        font-size: 1.8rem;
        font-weight: 600;
      }
      .product-options-container p {
        margin-bottom: 8px;
        font-size: 1.5rem;
        color: rgba(var(--color-foreground), 0.8);
      }
      .requestInfo, .emailProduct {
        text-decoration: inherit;
        background-color: #000;
        color: #fff;
        border-radius: 30px;
        padding: 10px;
        width: 100%;
        text-align: center;
        border: 1px solid #000;
      }
      .requestInfo:hover, .emailProduct:hover {
        background-color: #fff;
        color: #000;
        transition: 0.4s;
        border: 1px solid #000;
      }
    </style>
    <!-- Inventory Modal -->
    <basic-modal id="inventoryModal" class="drawer modal" style="--modal-width: 77rem;">
      <div class="fixed-overlay" aria-controls="inventoryModal"></div>
      <div class="drawer__inner color-{{ settings.overlay_color_scheme }}">
        <button
          class="drawer__close-btn"
          aria-controls="inventoryModal"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="drawer__body v-scrollable h-full">
          <h2 class="h2 product__popup-page-title">Product Inventory</h2>
          <!-- Product Display -->
          <div class="form-group" style="display: flex; flex-direction: column; margin-bottom: 20px; width: 100%;">
            <label style="display: block; margin-bottom: 8px; width: 100%;"><strong>Product</strong></label>
            <p id="inventory-product-display" style="display: block; margin: 0; padding: 0; color: rgba(var(--color-foreground), 0.8); text-align: left; width: 100%;">Loading product information...</p>
          </div>
          <div id="inventoryContent">
            <p>Loading inventory information...</p>
          </div>
        </div>
      </div>
    </basic-modal>

    <!-- Request Info Modal -->
    <basic-modal id="requestInfoModal" class="drawer modal" style="--modal-width: 77rem;">
      <div class="fixed-overlay" aria-controls="requestInfoModal"></div>
      <div class="drawer__inner color-{{ settings.overlay_color_scheme }}">
        <button
          class="drawer__close-btn"
          aria-controls="requestInfoModal"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="drawer__body v-scrollable h-full">
          <h2 class="h2 product__popup-page-title">Request Additional Information</h2>
          <form id="requestInfoForm" class="product__popup-form">
            <!-- Product Display -->
            <div class="form-group" style="margin-bottom: 0px;">
              <label style="margin-bottom: 8px;"><strong>Product</strong></label>
              <p id="request-product-display" style="margin: 0; padding: 0; color: rgba(var(--color-foreground), 0.8); text-align: left; width: 100%;">Loading product information...</p>
            </div>
            
            <!-- Quantity Needed and Date Needed (Two columns) -->
            <div class="form-row form-row--two">
              <div class="form-group">
                <label for="request-quantity">Quantity Needed</label>
                <input type="text" id="request-quantity" name="quantity" class="form-control">
              </div>
              <div class="form-group">
                <label for="request-date">Date Needed</label>
                <input type="text" id="request-date" name="date_needed" class="form-control">
              </div>
            </div>
            
            <!-- Comments (Full width) -->
            <div class="form-group">
              <label for="request-comments">Comments</label>
              <textarea id="request-comments" name="comments" class="form-control" rows="5"></textarea>
            </div>
            
            <!-- First Name and Last Name (Two columns) -->
            <div class="form-row form-row--two">
              <div class="form-group">
                <label for="request-first-name">First Name <span style="color: red;">*</span></label>
                <input type="text" id="request-first-name" name="first_name" required class="form-control">
              </div>
              <div class="form-group">
                <label for="request-last-name">Last Name <span style="color: red;">*</span></label>
                <input type="text" id="request-last-name" name="last_name" required class="form-control">
              </div>
            </div>
            
            <!-- Email (Full width) -->
            <div class="form-group">
              <label for="request-email">Email <span style="color: red;">*</span></label>
              <input type="email" id="request-email" name="email" required class="form-control">
            </div>
            
            <!-- Phone, Extension, Fax (Three columns) -->
            <div class="form-row form-row--three">
              <div class="form-group">
                <label for="request-phone">Phone <span style="color: red;">*</span></label>
                <input type="tel" id="request-phone" name="phone" required class="form-control">
              </div>
              <div class="form-group">
                <label for="request-extension">Extension</label>
                <input type="text" id="request-extension" name="extension" class="form-control">
              </div>
              <div class="form-group">
                <label for="request-fax">Fax</label>
                <input type="text" id="request-fax" name="fax" class="form-control">
              </div>
            </div>
            
            <!-- Company Name (Full width) -->
            <div class="form-group">
              <label for="request-company">Company Name</label>
              <input type="text" id="request-company" name="company" class="form-control">
            </div>
            
            <!-- Street Address (Full width) -->
            <div class="form-group">
              <label for="request-address">Street Address</label>
              <input type="text" id="request-address" name="address" class="form-control">
            </div>
            
            <!-- City, State, Zip (Three columns) -->
            <div class="form-row form-row--three">
              <div class="form-group">
                <label for="request-city">City</label>
                <input type="text" id="request-city" name="city" class="form-control">
              </div>
              <div class="form-group">
                <label for="request-state">State</label>
                <input type="text" id="request-state" name="state" class="form-control">
              </div>
              <div class="form-group">
                <label for="request-zip">Zip</label>
                <input type="text" id="request-zip" name="zip" class="form-control">
              </div>
            </div>
            
            <!-- Send copy checkbox -->
            <div class="form-group">
              <label style="display: flex; align-items: center; font-weight: normal; cursor: pointer;">
                <input type="checkbox" id="request-send-copy" name="send_copy" value="yes">
                <span>Send a copy of this email to me</span>
              </label>
            </div>
            
            <!-- Hidden fields for product data -->
            <input type="hidden" id="request-product-title" name="product_title" value="{{ product.title | escape }}">
            <input type="hidden" id="request-product-sku" name="product_sku" value="{{ product.selected_or_first_available_variant.sku }}">
            <input type="hidden" id="request-product-url" name="product_url" value="{{ product.url }}">
            
            <button type="submit" class="btn btn--primary" style="margin-top: 20px;">Send Request</button>
          </form>
        </div>
      </div>
    </basic-modal>

    <!-- Email Product Modal -->
    <basic-modal id="emailProductModal" class="drawer modal" style="--modal-width: 77rem;">
      <div class="fixed-overlay" aria-controls="emailProductModal"></div>
      <div class="drawer__inner color-{{ settings.overlay_color_scheme }}">
        <button
          class="drawer__close-btn"
          aria-controls="emailProductModal"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="drawer__body v-scrollable h-full">
          <h2 class="h2 product__popup-page-title">Email Product</h2>
          <form id="emailProductForm" class="product__popup-form">
            <!-- Product Display -->
            <div class="form-group" style="margin-bottom: 0px;">
              <label style="margin-bottom: 8px;"><strong>Product</strong></label>
              <p id="form-product-display" style="margin: 0; padding: 0; color: rgba(var(--color-foreground), 0.8); text-align: left; width: 100%;">Loading product information...</p>
            </div>
            
            <!-- Recipient Email -->
            <div class="form-group">
              <label for="email-to">Recipient Email <span style="color: red;">*</span></label>
              <input type="email" id="email-to" name="to" required class="form-control">
              <p style="margin: 4px 0 0 0; font-size: 0.875rem; color: rgba(var(--color-foreground), 0.6);">Use commas or semicolons (no spaces) to separate multiple addresses</p>
            </div>
            
            <!-- Your Email -->
            <div class="form-group">
              <label for="email-from">Your Email <span style="color: red;">*</span></label>
              <input type="email" id="email-from" name="from_email" required class="form-control">
            </div>
            
            <!-- Your Name -->
            <div class="form-group">
              <label for="email-name">Your Name</label>
              <input type="text" id="email-name" name="from_name" class="form-control">
            </div>
            
            <!-- Subject -->
            <div class="form-group">
              <label for="email-subject">Subject <span style="color: red;">*</span></label>
              <input type="text" id="email-subject" name="subject" required class="form-control">
            </div>
            
            <!-- Message -->
            <div class="form-group">
              <label for="email-message">Message</label>
              <textarea id="email-message" name="message" class="form-control" rows="5"></textarea>
            </div>
            
            <!-- Send a copy checkbox -->
            <div class="form-group">
              <label style="display: flex; align-items: center; font-weight: normal; cursor: pointer;">
                <input type="checkbox" id="email-send-copy" name="send_copy" value="yes">
                <span>Send a copy of this email to this address:</span>
              </label>
              <input type="email" id="email-copy-address" name="copy_email" class="form-control" style="margin-top: 8px;" placeholder="Enter email address">
            </div>
            
            <!-- Hidden fields for product data -->
            <input type="hidden" id="form-product-title" name="product_title" value="{{ product.title | escape }}">
            <input type="hidden" id="form-product-sku" name="product_sku" value="{{ product.selected_or_first_available_variant.sku }}">
            <input type="hidden" id="form-product-url" name="product_url" value="{{ product.url }}">
            
            <button type="submit" class="btn btn--primary" style="margin-top: 20px;">Send Email</button>
          </form>
        </div>
      </div>
    </basic-modal>

    <!-- Sales Tools Modal -->
    <basic-modal id="salesToolsModal" class="drawer modal" style="--modal-width: 77rem;">
      <div class="fixed-overlay" aria-controls="salesToolsModal"></div>
      <div class="drawer__inner color-{{ settings.overlay_color_scheme }}">
        <button
          class="drawer__close-btn"
          aria-controls="salesToolsModal"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="drawer__body v-scrollable h-full">
          <h2 class="h2 product__popup-page-title">Sales Tools</h2>
          <!-- Product Display -->
          <div class="form-group" style="display: flex; flex-direction: column; margin-bottom: 20px; width: 100%;">
            <label style="display: block; margin-bottom: 8px; width: 100%;"><strong>Product</strong></label>
            <p id="sales-tools-product-display" style="display: block; margin: 0; padding: 0; color: rgba(var(--color-foreground), 0.8); text-align: left; width: 100%;">Loading product information...</p>
          </div>
          <div id="salesToolsContent">
            <p>Loading sales tools...</p>
          </div>
        </div>
      </div>
    </basic-modal>

    <!-- Product Options Modal -->
    <basic-modal id="productOptionsModal" class="drawer modal" style="--modal-width: 77rem;">
      <div class="fixed-overlay" aria-controls="productOptionsModal"></div>
      <div class="drawer__inner color-{{ settings.overlay_color_scheme }}">
        <button
          class="drawer__close-btn"
          aria-controls="productOptionsModal"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="drawer__body v-scrollable h-full">
          <h2 class="h2 product__popup-page-title">Product Options</h2>
          <!-- Product Display -->
          <div class="form-group" style="display: flex; flex-direction: column; margin-bottom: 20px; width: 100%;">
            <label style="display: block; margin-bottom: 8px; width: 100%;"><strong>Product</strong></label>
            <p id="product-options-product-display" style="display: block; margin: 0; padding: 0; color: rgba(var(--color-foreground), 0.8); text-align: left; width: 100%;">Loading product information...</p>
          </div>
          <div id="productOptionsContent">
            <p>Loading product options...</p>
          </div>
        </div>
      </div>
    </basic-modal>
  {%- endif -%}

  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
  <script>
    (function() {
      'use strict';
      
      // Initialize EmailJS
      if (typeof emailjs !== 'undefined') {
    emailjs.init("u24h0rlyz_5EglBDe");
      }

      // Helper function to get product data (works with dynamic content)
      function getProductData() {
        const productInfo = document.querySelector('product-info');
        if (productInfo) {
          const productId = productInfo.dataset.productId;
          const productJson = document.querySelector(`#ProductJSON-${productId}`);
          if (productJson) {
            try {
              return JSON.parse(productJson.textContent);
            } catch(e) {
              console.error('Error parsing product JSON:', e);
            }
          }
        }
        return null;
      }

      // Helper function to get current variant SKU
      function getCurrentVariantSKU() {
        const variantSelects = document.querySelector('variant-selects');
        if (variantSelects) {
          const selectedVariant = variantSelects.selectedVariant;
          if (selectedVariant && selectedVariant.sku) {
            return selectedVariant.sku;
          }
        }
        // Fallback to first available variant
        const productInfo = document.querySelector('product-info');
        if (productInfo) {
          const productId = productInfo.dataset.productId;
          const productJson = document.querySelector(`script[type="application/json"]#ProductJSON-${productId}`);
          if (productJson) {
            try {
              const product = JSON.parse(productJson.textContent);
              return product.selected_or_first_available_variant?.sku || '';
            } catch(e) {
              console.error('Error parsing product JSON:', e);
            }
          }
        }
        return '';
      }

      // Helper function to close basic-modal
      function closeModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) {
          // Try to find close button and click it
          const closeBtn = modal.querySelector('.drawer__close-btn');
          if (closeBtn) {
            closeBtn.click();
          } else if (typeof modal.hide === 'function') {
            modal.hide();
          } else {
            // Fallback: dispatch escape key event
            const escapeEvent = new KeyboardEvent('keydown', { key: 'Escape', bubbles: true });
            modal.dispatchEvent(escapeEvent);
          }
        }
      }

      // Event delegation for dynamically loaded buttons
      // Let basic-modal handle opening natively via aria-controls, but update data first
      document.addEventListener('click', function(e) {
        const target = e.target.closest('.showInventory, .requestInfo, .emailProduct, .salesTools, .showProductOptions');
        if (!target) return;

        // Don't prevent default - let basic-modal handle it natively
        // But update data before the modal opens
        
        if (target.classList.contains('showInventory')) {
          // Load inventory data before modal opens
          loadInventoryData();
          // Small delay to ensure modal is opening
          setTimeout(() => {
            const modal = document.getElementById('inventoryModal');
            if (modal) {
              // Ensure content is loaded
              loadInventoryData();
            }
          }, 100);
        } else if (target.classList.contains('requestInfo')) {
          // Update form with current product data
          updateRequestInfoForm();
        } else if (target.classList.contains('emailProduct')) {
          // Update form with current product data
          updateEmailProductForm();
        } else if (target.classList.contains('salesTools')) {
          // Load sales tools content
          loadSalesToolsContent();
        } else if (target.classList.contains('showProductOptions')) {
          // Load product options content
          loadProductOptionsContent();
        }
      });

      // Listen for modal open events to ensure data is fresh
      document.addEventListener('modal:opened', function(e) {
        const modalId = e.target?.id;
        if (modalId === 'inventoryModal') {
          loadInventoryData();
        } else if (modalId === 'requestInfoModal') {
          updateRequestInfoForm();
        } else if (modalId === 'emailProductModal') {
          updateEmailProductForm();
        } else if (modalId === 'salesToolsModal') {
          loadSalesToolsContent();
        } else if (modalId === 'productOptionsModal') {
          loadProductOptionsContent();
        }
      });

      // Load inventory data
      function loadInventoryData() {
        const inventoryContent = document.getElementById('inventoryContent');
        if (!inventoryContent) return;

        // Update product display
        const productTitle = document.querySelector('h1.product__title')?.textContent?.trim() || 
                           '{{ product.title | escape }}';
        const productSKU = getCurrentVariantSKU() || '{{ product.selected_or_first_available_variant.sku }}';
        const inventoryDisplayElement = document.getElementById('inventory-product-display');
        if (inventoryDisplayElement) {
          const displayText = productSKU ? `# ${productSKU} - ${productTitle}` : productTitle;
          inventoryDisplayElement.textContent = displayText;
        }

        inventoryContent.innerHTML = '<p>Loading inventory information...</p>';

        const productInfo = document.querySelector('product-info');
        if (!productInfo) {
          inventoryContent.innerHTML = '<p>Product information not available.</p>';
          return;
        }

        const productId = productInfo.dataset.productId;
        const productUrl = productInfo.dataset.url || window.location.pathname;
        
        // Try multiple methods to get product data
        let productData = null;
        
        // Method 1: Try to get from variant-selects element
        const variantSelects = document.querySelector('variant-selects');
        if (variantSelects) {
          // Check various properties where product data might be stored
          if (variantSelects.product) {
            productData = variantSelects.product;
          } else if (variantSelects.dataset && variantSelects.dataset.product) {
            try {
              productData = JSON.parse(variantSelects.dataset.product);
            } catch(e) {
              console.error('Error parsing product data from dataset:', e);
            }
          }
        }
        
        // Method 2: Try to get from structured data (LD+JSON)
        if (!productData) {
          const structuredData = document.querySelector('script[type="application/ld+json"]');
          if (structuredData) {
            try {
              const ldData = JSON.parse(structuredData.textContent);
              if (ldData && ldData['@graph']) {
                const productNode = ldData['@graph'].find(node => node['@type'] === 'Product');
                if (productNode && productNode.offers && productNode.offers.offers) {
                  // Convert structured data to our format
                  productData = {
                    variants: productNode.offers.offers.map((offer, index) => ({
                      id: offer.sku || index,
                      title: offer.name || productNode.name || 'Default',
                      sku: offer.sku || '',
                      available: offer.availability === 'https://schema.org/InStock',
                      inventory_quantity: null,
                      inventory_management: null
                    }))
                  };
                }
              }
            } catch(e) {
              console.error('Error parsing structured data:', e);
            }
          }
        }
        
        // Method 3: Fetch from Shopify product JSON endpoint
        if (!productData) {
          // Use Shopify's product JSON endpoint
          // Extract product handle from URL
          let productHandle = '';
          if (productUrl.includes('/products/')) {
            productHandle = productUrl.split('/products/')[1].split('?')[0].split('#')[0];
          } else {
            // If URL is just a path, extract handle
            productHandle = productUrl.replace(/^\//, '').replace(/\/$/, '').split('?')[0];
          }
          
          if (!productHandle) {
            // Fallback: try to get from current page URL
            productHandle = window.location.pathname.split('/products/')[1]?.split('?')[0] || '';
          }
          
          if (!productHandle) {
            getInventoryFromPage();
            return;
          }
          
          const jsonUrl = `/products/${productHandle}.js`;
          fetch(jsonUrl)
            .then(response => {
              if (!response.ok) {
                throw new Error('Failed to fetch product data');
              }
              return response.json();
            })
            .then(data => {
              if (data && data.variants) {
                displayInventoryData({ variants: data.variants });
              } else {
                getInventoryFromPage();
              }
            })
            .catch(error => {
              console.error('Error fetching product JSON:', error);
              // Fallback to page scraping
              getInventoryFromPage();
            });
          return; // Exit early, displayInventoryData will be called in fetch
        }
        
        // If we have product data, display it
        if (productData) {
          displayInventoryData(productData);
        } else {
          getInventoryFromPage();
        }
        
        function getInventoryFromPage() {
          // Try to extract variant data from variant-selects options
          const variantSelects = document.querySelector('variant-selects');
          if (!variantSelects) {
            inventoryContent.innerHTML = '<div class="inventory-list"><p>Unable to load inventory information. Please refresh the page.</p></div>';
            return;
          }
          
          // Try to find variant option elements
          const variantOptions = variantSelects.querySelectorAll('input[type="radio"], select option, [data-variant-id]');
          
          if (variantOptions.length === 0) {
            // Try to get from selected variant data
            const selectedVariantEl = variantSelects.querySelector('[data-selected-variant]');
            if (selectedVariantEl) {
              try {
                const selectedVariant = JSON.parse(selectedVariantEl.textContent);
                displayInventoryData({ variants: [selectedVariant] });
                return;
              } catch(e) {
                console.error('Error parsing selected variant:', e);
              }
            }
            
            // Show current variant info from inventory block
            const currentInventory = document.querySelector('#Inventory-' + productInfo.dataset.section);
            if (currentInventory) {
              inventoryContent.innerHTML = '<div class="inventory-list"><p><strong>Current Variant:</strong><br>' + currentInventory.textContent.trim() + '</p><p>For full inventory details, please contact us.</p></div>';
            } else {
              inventoryContent.innerHTML = '<div class="inventory-list"><p>Inventory information is not available for this product. Please contact us for availability.</p></div>';
            }
            return;
          }
          
          // Build table from variant options
          let html = '<div class="inventory-list">';
          html += '<table class="inventory-table" style="width: 100%; border-collapse: collapse; margin-top: 20px;">';
          html += '<thead><tr><th style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5;">Variant</th><th style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5;">SKU</th><th style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5;">Status</th></tr></thead>';
          html += '<tbody>';
          
          variantOptions.forEach(option => {
            const variantTitle = option.textContent?.trim() || option.value || 'Default';
            const sku = option.dataset?.sku || option.value || 'N/A';
            const available = option.dataset?.available === 'true' || !option.disabled ? 'Available' : 'Unavailable';
            
            html += `<tr>
              <td style="padding: 10px; border: 1px solid #ddd;">${variantTitle}</td>
              <td style="padding: 10px; border: 1px solid #ddd;">${sku}</td>
              <td style="padding: 10px; border: 1px solid #ddd;">${available}</td>
            </tr>`;
          });
          
          html += '</tbody></table>';
          html += '</div>';
          inventoryContent.innerHTML = html;
        }
        
        function displayInventoryData(product) {
          const variants = product.variants || [];
          let html = '<div class="inventory-list">';
          
          if (variants.length > 0) {
            html += '<table class="inventory-table" style="width: 100%; border-collapse: collapse; margin-top: 20px;">';
            html += '<thead><tr><th style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5;">Variant</th><th style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5;">SKU</th><th style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5;">Inventory</th><th style="padding: 10px; border: 1px solid #ddd; background: #f5f5f5;">Status</th></tr></thead>';
            html += '<tbody>';
            
            variants.forEach(variant => {
              const variantTitle = variant.title || variant.name || 'Default';
              const sku = variant.sku || 'N/A';
              let inventory = 'N/A';
              let status = 'Unknown';
              
              if (variant.inventory_management === 'shopify') {
                if (variant.inventory_quantity !== null && variant.inventory_quantity !== undefined) {
                  inventory = variant.inventory_quantity;
                  if (variant.inventory_quantity > 0) {
                    status = variant.inventory_quantity <= 10 ? 'Low Stock' : 'In Stock';
                  } else {
                    status = variant.inventory_policy === 'continue' ? 'Backorder' : 'Out of Stock';
                  }
                } else {
                  inventory = 'Unlimited';
                  status = 'Available';
                }
              } else {
                inventory = 'Not Tracked';
                status = variant.available ? 'Available' : 'Unavailable';
              }
              
              html += `<tr>
                <td style="padding: 10px; border: 1px solid #ddd;">${variantTitle}</td>
                <td style="padding: 10px; border: 1px solid #ddd;">${sku}</td>
                <td style="padding: 10px; border: 1px solid #ddd;">${inventory}</td>
                <td style="padding: 10px; border: 1px solid #ddd;">${status}</td>
              </tr>`;
            });
            
            html += '</tbody></table>';
          } else {
            html += '<p>No variant information available.</p>';
          }
          
          html += '</div>';
          inventoryContent.innerHTML = html;
        }
      }

      // Update request info form
      function updateRequestInfoForm() {
