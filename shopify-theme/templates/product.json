        "collapsible_tab_j9cEGj": {
          "type": "collapsible_tab",
          "disabled": true,
          "settings": {
            "heading": "Product Options",
            "heading_size": "h4",
            "icon": "none",
            "content": "",
            "custom_liquid": "{%- liquid\n  assign has_options = false\n  assign pms_charges = product.metafields.custom.pms_charges.value\n  assign addition_imprint_charges = product.metafields.custom.addition_imprint_charges.value\n  assign imprint_method_charge = product.metafields.custom.imprint_method_charge.value\n  \n  if pms_charges != blank or addition_imprint_charges != blank or imprint_method_charge != blank\n    assign has_options = true\n  endif\n-%}\n\n{%- if has_options -%}\n  <style>\n    .product-options-container {\n      border: 1px solid rgba(var(--color-foreground), 0.1);\n      border-radius: 4px;\n      padding: 20px;\n      margin-bottom: 20px;\n      background-color: rgba(var(--color-background), 1);\n    }\n    .product-options-container h3 {\n      margin-bottom: 15px;\n      font-size: 1.8rem;\n      font-weight: 600;\n    }\n    .product-options-container p {\n      margin-bottom: 8px;\n      font-size: 1.5rem;\n      color: rgba(var(--color-foreground), 0.8);\n    }\n  </style>\n\n  {%- if pms_charges != blank -%}\n    {%- liquid\n      assign pms_str = pms_charges | downcase\n      assign price_found = false\n      assign price_value = 0\n      assign unit_part = ''\n      \n      if pms_str contains '$'\n        assign parts = pms_charges | split: '$'\n        if parts.size > 1\n          assign price_part = parts[1] | split: '(' | first | split: ')' | first | split: ' ' | first\n          if price_part != blank\n            assign price_value = price_part | plus: 0\n            if price_value > 0\n              assign price_found = true\n              assign unit_part = pms_charges | remove: price_part | remove: '$' | remove: '(V)' | strip\n              if unit_part == blank\n                assign unit_parts = pms_str | split: 'per'\n                if unit_parts.size > 1\n                  assign unit_part = unit_parts[1] | strip\n                endif\n              endif\n            endif\n          endif\n        endif\n      endif\n    -%}\n    <div class=\"product-options-container\">\n      <h3>PMS Charge</h3>\n      {%- if price_found -%}\n        <p>Price: ${{ price_value }} {{ unit_part | downcase }}</p>\n      {%- else -%}\n        <p>{{ pms_charges }}</p>\n      {%- endif -%}\n    </div>\n  {%- endif -%}\n\n  {%- if addition_imprint_charges != blank -%}\n    {%- liquid\n      assign charges_str = addition_imprint_charges | downcase\n      assign container_title = '2nd Location Run Charge'\n      \n      if charges_str contains 'per color'\n        assign container_title = '2nd Color Run Charge'\n      elsif charges_str contains '2nd pole imprint'\n        assign container_title = '2nd Pole Golf Balls'\n      endif\n      \n      assign price_found = false\n      assign setup_found = false\n      assign main_price = 0\n      assign setup_price = 0\n      assign price_unit = 'each'\n      \n      if addition_imprint_charges contains '$'\n        assign dollar_parts = addition_imprint_charges | split: '$'\n        for part in dollar_parts\n          if forloop.first\n            continue\n          endif\n          \n          assign clean_part = part | strip\n          assign num_part = clean_part | split: '(' | first | split: '{' | first | split: ')' | first | split: ' ' | first\n          \n          if num_part != blank\n            assign num_value = num_part | plus: 0\n            if num_value > 0\n              assign lower_part = clean_part | downcase\n              if lower_part contains 'setup' or lower_part contains 'charge'\n                unless setup_found\n                  assign setup_price = num_value\n                  assign setup_found = true\n                endunless\n              else\n                unless price_found\n                  assign main_price = num_value\n                  assign price_found = true\n                  \n                  if lower_part contains 'dozen'\n                    assign price_unit = 'per dozen'\n                  else\n                    assign price_unit = 'each'\n                  endif\n                endunless\n              endif\n            endif\n          endif\n        endfor\n      endif\n    -%}\n    <div class=\"product-options-container\">\n      <h3>{{ container_title }}</h3>\n      {%- if price_found -%}\n        <p>Price: ${{ main_price }} {{ price_unit }}</p>\n      {%- endif -%}\n      {%- if setup_found -%}\n        {%- if container_title == '2nd Location Run Charge' -%}\n          <p>Setup Charge: ${{ setup_price }} per location</p>\n        {%- else -%}\n          <p>Setup Charge: ${{ setup_price }} each</p>\n        {%- endif -%}\n      {%- endif -%}\n      {%- unless price_found or setup_found -%}\n        <p>{{ addition_imprint_charges }}</p>\n      {%- endunless -%}\n    </div>\n  {%- endif -%}\n\n  {%- if imprint_method_charge != blank -%}\n    {%- liquid\n      assign price_found = false\n      assign setup_found = false\n      assign main_price = 0\n      assign setup_price = 0\n      \n      if imprint_method_charge contains '$'\n        assign dollar_parts = imprint_method_charge | split: '$'\n        for part in dollar_parts\n          if forloop.first\n            continue\n          endif\n          \n          assign clean_part = part | strip\n          assign num_part = clean_part | split: '(' | first | split: ' ' | first\n          \n          if num_part != blank\n            assign num_value = num_part | plus: 0\n            if num_value > 0\n              assign lower_part = clean_part | downcase\n              if lower_part contains 'setup' or lower_part contains 'charge'\n                unless setup_found\n                  assign setup_price = num_value\n                  assign setup_found = true\n                endunless\n              elsif lower_part contains 'per pc' or lower_part contains 'per piece'\n                unless price_found\n                  assign main_price = num_value\n                  assign price_found = true\n                endunless\n              endif\n            endif\n          endif\n        endfor\n      endif\n    -%}\n    <div class=\"product-options-container\">\n      <h3>FCD Upgrade Charge</h3>\n      {%- if price_found -%}\n        <p>Price: ${{ main_price }} each</p>\n      {%- endif -%}\n      {%- if setup_found -%}\n        <p>Setup Charge: ${{ setup_price }} each</p>\n      {%- endif -%}\n      {%- unless price_found or setup_found -%}\n        <p>{{ imprint_method_charge }}</p>\n      {%- endunless -%}\n    </div>\n  {%- endif -%}\n\n{%- else -%}\n  <p>No product options available for this product.</p>\n{%- endif -%}",
            "page": "",
            "default_open": false,
            "show_below_product_media": true
          }
        },
