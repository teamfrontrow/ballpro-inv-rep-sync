            "icon": "none",
            "content": "",
            "custom_liquid": "{%- liquid\n  assign product_title_lower = product.title | downcase\n  assign contains_golf_balls = false\n  assign contains_wilson_50 = false\n  assign contains_wilson_duo_soft = false\n  assign contains_callaway_dozen_box = false\n  assign contains_dozen_titleist = false\n  assign contains_baseball = false\n  assign contains_keychain = false\n  assign contains_acrylic = false\n  assign contains_bat = false\n  assign contains_cooler = false\n  assign contains_synthetic = false\n  assign show_golf_ball_template = false\n  assign show_baseball_template = false\n  assign template_shown = false\n  \n  if product_title_lower contains 'golf balls'\n    assign contains_golf_balls = true\n  endif\n  \n  if product_title_lower contains 'wilson 50'\n    assign contains_wilson_50 = true\n  endif\n  \n  if product_title_lower contains 'wilson duo soft'\n    assign contains_wilson_duo_soft = true\n  endif\n  \n  if product_title_lower contains 'callaway dozen box'\n    assign contains_callaway_dozen_box = true\n  endif\n  \n  if product_title_lower contains 'dozen titleist'\n    assign contains_dozen_titleist = true\n  endif\n  \n  if product_title_lower contains 'baseball'\n    assign contains_baseball = true\n  endif\n  \n  if product_title_lower contains 'keychain'\n    assign contains_keychain = true\n  endif\n  \n  if product_title_lower contains 'acrylic'\n    assign contains_acrylic = true\n  endif\n  \n  if product_title_lower contains 'bat'\n    assign contains_bat = true\n  endif\n  \n  if product_title_lower contains 'cooler'\n    assign contains_cooler = true\n  endif\n  \n  if product_title_lower contains 'synthetic'\n    assign contains_synthetic = true\n  endif\n  \n  if contains_golf_balls and contains_wilson_50 == false and contains_wilson_duo_soft == false\n    assign show_golf_ball_template = true\n    assign template_shown = true\n  endif\n  \n  if contains_callaway_dozen_box\n    assign show_golf_ball_template = true\n    assign template_shown = true\n  endif\n  \n  if contains_dozen_titleist\n    assign show_golf_ball_template = true\n    assign template_shown = true\n  endif\n  \n  if contains_baseball and contains_keychain == false and contains_acrylic == false and contains_bat == false and contains_cooler == false and contains_synthetic == false\n    assign show_baseball_template = true\n    assign template_shown = true\n  endif\n-%}\n\n<style>\n  .sales-tools-container {\n    border: 1px solid rgba(var(--color-foreground), 0.1);\n    border-radius: 4px;\n    padding: 20px;\n    background-color: rgba(var(--color-background), 1);\n    margin-top: 20px;\n  }\n  .sales-tools-container h3 {\n    margin-bottom: 15px;\n    font-size: 1.8rem;\n    font-weight: 600;\n  }\n  .sales-tools-container p {\n    margin-bottom: 15px;\n    font-size: 1.5rem;\n    color: rgba(var(--color-foreground), 0.8);\n  }\n  .sales-tools-container a {\n    color: rgba(var(--color-foreground), 1);\n    text-decoration: underline;\n    font-size: 1.6rem;\n    display: block;\n    margin-bottom: 10px;\n  }\n  .sales-tools-container .no-template {\n    color: rgba(var(--color-foreground), 0.6);\n    font-size: 1.5rem;\n    margin-bottom: 10px;\n  }\n</style>\n\n<div class=\"sales-tools-container\">\n  <h3>Artwork Templates</h3>\n  <p>Templates for artwork layout and margin information.</p>\n  \n  {%- if show_golf_ball_template -%}\n    <a href=\"https://s3.distributorcentral.com/uploads/6/E/6EA141D552BAB890BA6B424986067D97.pdf\" target=\"_blank\">View Golf Ball Template</a>\n  {%- endif -%}\n  \n  {%- if show_baseball_template -%}\n    <a href=\"https://s3.distributorcentral.com/uploads/0/C/0C560CA6CD4EFCAAA0BC14E6970CDE38.pdf\" target=\"_blank\">Template</a>\n  {%- endif -%}\n  \n  {%- unless template_shown -%}\n    <p class=\"no-template\">Template not available for this product.</p>\n  {%- endunless -%}\n</div>",
            "page": "",
            "default_open": false,
            "show_below_product_media": true
          }
        },
        "collapsible_tab_PmrKCe": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Sales Tools",
            "heading_size": "h4",
            "icon": "none",
            "content": "",
            "custom_liquid": "{%- assign sales_tool_templates = product.metafields.custom.sales_tool_template.value -%}\n{%- assign sales_tool_sales_sheet = product.metafields.custom['sales_tool_sales_sheet'] | default: '' | strip -%}\n\n{%- assign sales_sheet_filename = '' -%}\n{%- if sales_tool_sales_sheet != '' -%}\n  {%- assign sales_sheet_filename = sales_tool_sales_sheet | split: '/' | last -%}\n  {%- assign sales_sheet_filename = sales_sheet_filename | split: '?' | first -%}\n{%- endif -%}\n\n<style>\n  .sales-tools-container {\n    border: 1px solid rgba(var(--color-foreground), 0.1);\n    border-radius: 4px;\n    padding: 20px;\n    background-color: rgba(var(--color-background), 1);\n    margin-top: 20px;\n  }\n  .sales-tools-container h3 {\n    margin-bottom: 15px;\n    font-size: 1.8rem;\n    font-weight: 600;\n  }\n  .sales-tools-container p {\n    margin-bottom: 15px;\n    font-size: 1.5rem;\n    color: rgba(var(--color-foreground), 0.8);\n  }\n  .sales-tools-container a {\n    color: rgba(var(--color-foreground), 1);\n    text-decoration: underline;\n    font-size: 1.6rem;\n    display: block;\n    margin-bottom: 10px;\n  }\n  .no-template {\n    color: rgba(var(--color-foreground), 0.6);\n    font-size: 1.5rem;\n  }\n</style>\n\n<div class=\"sales-tools-container\">\n  {%- if sales_tool_templates != blank and sales_tool_templates.size > 0 -%}\n    <h3>Artwork Templates</h3>\n    <p>Templates for artwork layout and margin information.</p>\n    {%- for template_file in sales_tool_templates -%}\n      {%- assign tpl_url = template_file.url -%}\n      {%- assign tpl_display = template_file.alt -%}\n      {%- if tpl_display == blank -%}\n        {%- assign tpl_display = tpl_url | split: '/' | last | split: '?' | first -%}\n      {%- endif -%}\n      <a href=\"{{ tpl_url }}\" target=\"_blank\" rel=\"noopener\">\n        {{ tpl_display }}\n      </a>\n    {%- endfor -%}\n  {%- endif -%}\n\n  {%- if sales_tool_sales_sheet != '' -%}\n    <h3>Sales Sheet</h3>\n    <a href=\"{{ sales_tool_sales_sheet }}\" target=\"_blank\" rel=\"noopener\">\n      {{ sales_sheet_filename }}\n    </a>\n  {%- endif -%}\n\n  {%- if sales_tool_templates == blank and sales_tool_sales_sheet == '' -%}\n    <p class=\"no-template\">No sales tools for this product.</p>\n  {%- endif -%}\n</div>",
            "page": "",
            "default_open": false,
            "show_below_product_media": true
          }
        },
        "collapsible_tab_CG7Tb4": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Inventory",
            "heading_size": "h4",
            "icon": "none",
            "content": "",
            "custom_liquid": "{%- if product.variants.size > 0 -%}\n  <style>\n    .inventory-table {\n      width: 100%;\n      border-collapse: collapse;\n      margin-top: 20px;\n    }\n    .inventory-table th {\n      font-weight: 600;\n      text-align: left;\n      padding: 12px;\n      border: 1px solid rgba(var(--color-foreground), 0.1);\n    }\n    .inventory-table td {\n      padding: 12px;\n      border: 1px solid rgba(var(--color-foreground), 0.1);\n    }\n    .inventory-table tbody tr:hover {\n      background-color: rgba(var(--color-foreground), 0.05);\n    }\n  </style>\n  <div class=\"inventory-list\">\n    <table class=\"inventory-table\">\n      <thead>\n        <tr>\n          <th>Variant</th>\n          <th>SKU</th>\n          <th>Inventory</th>\n          <th>Status</th>\n        </tr>\n      </thead>\n      <tbody>\n        {%- for variant in product.variants -%}\n          {%- liquid\n            assign variant_title = variant.title | default: variant.name | default: 'Default'\n            assign variant_sku = variant.sku | default: 'N/A'\n            assign inventory_qty = 'N/A'\n            assign inventory_status = 'Unknown'\n            \n            if variant.inventory_management == 'shopify'\n              assign inventory_qty = variant.inventory_quantity\n              if variant.inventory_quantity > 0\n                if variant.inventory_quantity <= 10\n                  assign inventory_status = 'Low Stock'\n                else\n                  assign inventory_status = 'In Stock'\n                endif\n              else\n                if variant.inventory_policy == 'continue'\n                  assign inventory_status = 'Backorder'\n                else\n                  assign inventory_status = 'Out of Stock'\n                endif\n              endif\n            else\n              assign inventory_qty = 'Not Tracked'\n              if variant.available\n                assign inventory_status = 'Available'\n              else\n                assign inventory_status = 'Unavailable'\n              endif\n            endif\n          -%}\n          <tr>\n            <td>{{ variant_title }}</td>\n            <td>{{ variant_sku }}</td>\n            <td>{{ inventory_qty }}</td>\n            <td>{{ inventory_status }}</td>\n          </tr>\n        {%- endfor -%}\n      </tbody>\n    </table>\n  </div>\n{%- else -%}\n  <p>No variant information available.</p>\n{%- endif -%}",
            "page": "",
            "default_open": false,
            "show_below_product_media": true
          }
        },
