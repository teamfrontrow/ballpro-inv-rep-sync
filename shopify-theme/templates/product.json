          "disabled": true,
          "settings": {
            "custom_liquid": "<style>\n.pairedProduct {border-radius: 8px; background-color: green;color:white; margin-left: 10px; padding:1px 6px}\n</style>\n{% if product.metafields.custom.production_time_in_days %}\n\t<p><strong>Production Time in Days</strong></p>\n\t<p>{{ product.metafields.custom.production_time_in_days }} Working Days\n\t\n{% if product.metafields.custom.paired_product %}\n  {%- assign paired_product = product.metafields.custom.paired_product.value -%}\n\n  {% if paired_product %}\n    {%- assign prod_type = paired_product.metafields.custom.production_type.value -%}\n\n    {% if prod_type == \"factory\" %}\n      <span class=\"pairedProduct\"><a href=\"{{ paired_product.url }}\">See Factory Production Version</a></span>\n\n    {% elsif prod_type == \"in-house\" %}\n      <span class=\"pairedProduct\"><a href=\"{{ paired_product.url }}\">See In-house Production Version</a></span>\n    {% endif %}\n  {% endif %}\n{% endif %}\n\n</p>\n\t\n\t\n{% endif %}\n<div class=\"frd-pdp-additional-info\">\n<p><strong>Additional Info</strong></p>\n{% if product.metafields.custom.imprint_size %}\n\t<p>● Imprint Area: {{ product.metafields.custom.imprint_size }}</p>\n{% endif %}\n\n{% if product.metafields.custom.price_includes %}\n\t<p>● {{ product.metafields.custom.price_includes }}</p>\n{% endif %}\n\n{% if product.metafields.custom.add_prod_info %}\n\t<p>● {{ product.metafields.custom.add_prod_info }}</p>\n{% endif %}\n</div>"
