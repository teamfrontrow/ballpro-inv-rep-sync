            "custom_liquid": "{% if product.metafields.custom.sold_as_01.value %}\n\t<p><b>Sold As:</b> {{ product.metafields.custom.sold_as_01.value }} {{ product.metafields.custom.sold_as_02.value }}</p>\n{% endif %}\n \n \n\n\n{%- liquid\n  assign item_length = product.metafields.custom.item_length.value\n  assign item_width = product.metafields.custom.item_width.value\n  assign item_height = product.metafields.custom.item_height.value\n\n  assign has_length = false\n  assign has_width = false\n  assign has_height = false\n\n  if item_length != blank and item_length != 0 and item_length != '0'\n    assign has_length = true\n  endif\n\n  if item_width != blank and item_width != 0 and item_width != '0'\n    assign has_width = true\n  endif\n\n  if item_height != blank and item_height != 0 and item_height != '0'\n    assign has_height = true\n  endif\n\n  assign dimension_count = 0\n  if has_length\n    assign dimension_count = dimension_count | plus: 1\n  endif\n  if has_width\n    assign dimension_count = dimension_count | plus: 1\n  endif\n  if has_height\n    assign dimension_count = dimension_count | plus: 1\n  endif\n\n  assign dimensions = ''\n-%}\n\n{% if dimension_count > 0 %}\n  {% if dimension_count == 3 %}\n    {%- assign dimensions = item_length | append: ' L x ' | append: item_width | append: ' W x ' | append: item_height | append: ' H' -%}\n\n  {% elsif dimension_count == 2 %}\n    {%- if has_length and has_width -%}\n      {%- assign dimensions = item_length | append: ' L x ' | append: item_width | append: ' W' -%}\n    {%- elsif has_length and has_height -%}\n      {%- assign dimensions = item_length | append: ' L x ' | append: item_height | append: ' H' -%}\n    {%- elsif has_width and has_height -%}\n      {%- assign dimensions = item_width | append: ' W x ' | append: item_height | append: ' H' -%}\n    {%- endif -%}\n\n  {% elsif dimension_count == 1 %}\n    {%- if has_width -%}\n      {%- assign dimensions = item_width -%}\n    {%- elsif has_length -%}\n      {%- assign dimensions = item_length -%}\n    {%- elsif has_height -%}\n      {%- assign dimensions = item_height -%}\n    {%- endif -%}\n  {% endif %}\n\n  <p><b>Product Dimensions:</b> {{ dimensions }}</p>\n{% endif %}\n\n\n\n{% if product.metafields.custom.add_prod_info.value %}\n\t<p><b>Additional Product Details:</b> {{ product.metafields.custom.add_prod_info.value }}</p>\n{% endif %}\n\n\n{% if product.metafields.custom.materials.value %}\n\t<p><b>Product Material:</b> {{ product.metafields.custom.materials.value }}</p>\n{% endif %}\n\n{% if product.metafields.custom.prod_pack.value %}\n\t<p><b>Product Packaging:</b> {{ product.metafields.custom.prod_pack.value }}</p>\n{% endif %}",
