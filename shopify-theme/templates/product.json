        "imprintboard_ball_pro_customizer_button_qtzRWW": {
          "type": "shopify://apps/imprintboard-ball-pro/blocks/customizer-button/019e4c36-1ccc-7542-ba74-7819752aa7f9",
          "settings": {
            "button_text": "Customize This Product",
