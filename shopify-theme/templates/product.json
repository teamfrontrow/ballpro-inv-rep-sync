        "custom_liquid_TRJbFW": {
          "type": "custom_liquid",
          "name": "Custom Packaging Upgrade",
          "settings": {
            "custom_liquid": "{% assign custom_packaging_upgrade_image = product.metafields.custom.custom_packaging_upgrade.value %}\n\n{% if custom_packaging_upgrade_image %}\n<div class=\"cpk-wrapper\">\n  <button\n    type=\"button\"\n    class=\"cpk-button\"\n    aria-haspopup=\"dialog\"\n    aria-controls=\"cpk-modal\"\n    aria-expanded=\"false\"\n  >\n    Custom Packaging Upgrade\n  </button>\n\n  <div\n    id=\"cpk-modal\"\n    class=\"cpk-modal\"\n    role=\"dialog\"\n    aria-modal=\"true\"\n    aria-labelledby=\"cpk-modal-title\"\n    hidden\n  >\n    <div class=\"cpk-modal__overlay\" data-close-modal></div>\n\n    <div class=\"cpk-modal__content\">\n      <button\n        type=\"button\"\n        class=\"cpk-modal__close\"\n        aria-label=\"Close Custom Packaging Upgrade\"\n        data-close-modal\n      >\n        &times;\n      </button>\n\n      <h2 id=\"cpk-modal-title\" class=\"visually-hidden\">Custom Packaging Upgrade</h2>\n\n      <img\n        src=\"{{ custom_packaging_upgrade_image | image_url: width: 1100 }}\"\n        alt=\"Custom Packaging Upgrade\"\n        class=\"cpk-modal__image\"\n        loading=\"lazy\"\n      >\n    </div>\n  </div>\n</div>\n{% endif %}\n\n<style>\n  .cpk-button {\n    cursor: pointer;\n    padding: 10px 18px;\n    border: 1px solid #000;\n    background: #316951;\n    color: #FFF;\n    font-size: 14px;\n\twidth:100%;\n  }\n\n  .cpk-modal[hidden] {\n    display: none;\n  }\n.cpk-modal:not([hidden]) .cpk-modal__content {\n  transform: translateY(0);\n  opacity: 1;\n}\n.cpk-modal {\n  position: fixed;\n  inset: 0;\n  z-index: 9999;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.cpk-modal__overlay {\n  position: absolute;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.6);\n}\n\n.cpk-modal__content {\n  position: relative;\n  z-index: 1;\n\n  max-width: 80vw;\n  max-height: 800px;\n  border: solid 3px #316951;\n  background: #eee;\n  padding: 40px;\n  border-radius: 10px;\n transform: translateY(10px);\n  opacity: 0;\n  transition: all 0.2s ease;\n  overflow: auto;\n}\n\n  .cpk-modal__image {\n    display: block;\n    max-width: 100%;\n    height: auto;\n\tborder: solid 1px #555;\n  }\n\n  .cpk-modal__close {\n    position: absolute;\n    top: 1px;\n    right: 1px;\n    background: transparent;\n    border: 0;\n    font-size: 35px;\n    line-height: 1;\n    cursor: pointer;\n  }\n\n  .visually-hidden {\n    position: absolute !important;\n    width: 1px;\n    height: 1px;\n    padding: 0;\n    margin: -1px;\n    overflow: hidden;\n    clip: rect(0, 0, 0, 0);\n    white-space: nowrap;\n    border: 0;\n  }\n</style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    const button = document.querySelector('.cpk-button');\n    const modal = document.getElementById('cpk-modal');\n    const closeTargets = modal.querySelectorAll('[data-close-modal]');\n\n    if (!button || !modal) return;\n\n    button.addEventListener('click', function () {\n      modal.hidden = false;\n      button.setAttribute('aria-expanded', 'true');\n      document.body.style.overflow = 'hidden';\n    });\n\n    closeTargets.forEach(function (el) {\n      el.addEventListener('click', function () {\n        modal.hidden = true;\n        button.setAttribute('aria-expanded', 'false');\n        document.body.style.overflow = '';\n      });\n    });\n\n    document.addEventListener('keydown', function (event) {\n      if (event.key === 'Escape' && !modal.hidden) {\n        modal.hidden = true;\n        button.setAttribute('aria-expanded', 'false');\n        document.body.style.overflow = '';\n      }\n    });\n  });\n</script>"
          }
        },
        "custom_liquid_7FQMmq": {
          "type": "custom_liquid",
          "name": "Color Chart",
          "settings": {
            "custom_liquid": "{% assign color_chart_image = product.metafields.custom.color_chart.value %}\n\n{% if color_chart_image %}\n<div class=\"color-chart-wrapper\">\n  <button\n    type=\"button\"\n    class=\"color-chart-button\"\n    aria-haspopup=\"dialog\"\n    aria-controls=\"color-chart-modal\"\n    aria-expanded=\"false\"\n  >\n    Standard Imprint Colors\n\n\n  </button>\n\n  <div\n    id=\"color-chart-modal\"\n    class=\"color-chart-modal\"\n    role=\"dialog\"\n    aria-modal=\"true\"\n    aria-labelledby=\"color-chart-modal-title\"\n    hidden\n  >\n    <div class=\"color-chart-modal__overlay\" data-close-modal></div>\n\n    <div class=\"color-chart-modal__content\">\n      <button\n        type=\"button\"\n        class=\"color-chart-modal__close\"\n        aria-label=\"Close color chart\"\n        data-close-modal\n      >\n        &times;\n      </button>\n\n      <h2 id=\"color-chart-modal-title\" class=\"visually-hidden\">Color Chart</h2>\n\n      <img\n        src=\"{{ color_chart_image | image_url: width: 1200 }}\"\n        alt=\"Color Chart\"\n        class=\"color-chart-modal__image\"\n        loading=\"lazy\"\n      >\n    </div>\n  </div>\n</div>\n{% endif %}\n\n<style>\n  .color-chart-button {\n    cursor: pointer;\n    padding: 10px 18px;\n    border: 1px solid #000;\n    background: #316951;\n    color: #FFF;\n    font-size: 14px;\n\twidth:100%;\n  }\n\n  .color-chart-modal[hidden] {\n    display: none;\n  }\n.color-chart-modal:not([hidden]) .color-chart-modal__content {\n  transform: translateY(0);\n  opacity: 1;\n}\n.color-chart-modal {\n  position: fixed;\n  inset: 0;\n  z-index: 9999;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.color-chart-modal__overlay {\n  position: absolute;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.6);\n}\n\n.color-chart-modal__content {\n  position: relative;\n  z-index: 1;\n\n  max-width: 90vw;\n  max-height: 90vh;\n  border: solid 3px #316951;\n  background: #eee;\n  padding: 40px;\n  border-radius: 10px;\n transform: translateY(10px);\n  opacity: 0;\n  transition: all 0.2s ease;\n  overflow: auto;\n}\n\n  .color-chart-modal__image {\n    display: block;\n    max-width: 100%;\n    height: auto;\n\tborder: solid 1px #555;\n  }\n\n  .color-chart-modal__close {\n    position: absolute;\n    top: 1px;\n    right: 1px;\n    background: transparent;\n    border: 0;\n    font-size: 35px;\n    line-height: 1;\n    cursor: pointer;\n  }\n\n  .visually-hidden {\n    position: absolute !important;\n    width: 1px;\n    height: 1px;\n    padding: 0;\n    margin: -1px;\n    overflow: hidden;\n    clip: rect(0, 0, 0, 0);\n    white-space: nowrap;\n    border: 0;\n  }\n</style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    const button = document.querySelector('.color-chart-button');\n    const modal = document.getElementById('color-chart-modal');\n    const closeTargets = modal.querySelectorAll('[data-close-modal]');\n\n    if (!button || !modal) return;\n\n    button.addEventListener('click', function () {\n      modal.hidden = false;\n      button.setAttribute('aria-expanded', 'true');\n      document.body.style.overflow = 'hidden';\n    });\n\n    closeTargets.forEach(function (el) {\n      el.addEventListener('click', function () {\n        modal.hidden = true;\n        button.setAttribute('aria-expanded', 'false');\n        document.body.style.overflow = '';\n      });\n    });\n\n    document.addEventListener('keydown', function (event) {\n      if (event.key === 'Escape' && !modal.hidden) {\n        modal.hidden = true;\n        button.setAttribute('aria-expanded', 'false');\n        document.body.style.overflow = '';\n      }\n    });\n  });\n</script>"
          }
        },
