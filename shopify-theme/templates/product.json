            "content": "",
            "custom_liquid": "{% if product.metafields.custom.carton_length.value %}\n  <p><b>Carton Length:</b> {{ product.metafields.custom.carton_length.value }}\"</p>\n{% endif %}\n\n{% if product.metafields.custom.carton_width.value %}\n  <p><b>Carton Width:</b> {{ product.metafields.custom.carton_width.value }}\"</p>\n{% endif %}\n\n{% if product.metafields.custom.carton_height.value %}\n  <p><b>Carton Height:</b> {{ product.metafields.custom.carton_height.value }}\"</p>\n{% endif %}\n\n{% if product.metafields.custom.units_per_carton.value %}\n  <p><b>Units per Carton:</b> {{ product.metafields.custom.units_per_carton.value }}</p>\n{% endif %}\n\n{% assign first_variant = product.variants.first %}\n{% assign weight_unit = first_variant.weight_unit %}\n\n{% if weight_unit == 'lb' %}\n  {% assign weight_unit = 'lbs.' %}\n{% endif %}\n\n{% if product.metafields.custom.carton_weight_lbs.value %}\n  <p><b>Carton Weight (lbs):</b> {{ product.metafields.custom.carton_weight_lbs.value }} {{ weight_unit }}</p>\n{% endif %}\n\n{% if first_variant.weight_in_unit > 0 %}\n  <p><b>Weight per Unit of Sale (lbs):</b> {{ first_variant.weight_in_unit }} {{ weight_unit }}</p>\n{% endif %}\n\n{% assign zip_code = product.metafields.custom.zip_code.value | append: '' %}\n{% if zip_code != blank %}\n  {% assign padded_zip = zip_code | prepend: '00000' | slice: -5, 5 %}\n  <p><b>FOB:</b> {{ padded_zip }}</p>\n{% endif %}\n\n\n{% if product.metafields.custom.shipping_disclaimer.value %}\n  <p>{{ product.metafields.custom.shipping_disclaimer.value }}</p>\n{% endif %}",
