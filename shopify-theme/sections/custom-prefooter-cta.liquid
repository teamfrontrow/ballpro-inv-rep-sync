{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

{% style %}
  .section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --custom-prefooter-cta-text-width: {{ section.settings.text_width | divided_by: 10.0 }}rem;
  }

  .section-{{ section.id }} .custom-prefooter-cta__inner {
    text-align: center;
  }

  .section-{{ section.id }} .custom-prefooter-cta__heading {
    margin: 0 0 2.4rem;
    color: inherit;
  }

  .section-{{ section.id }} .custom-prefooter-cta__text {
    max-width: var(--custom-prefooter-cta-text-width);
    margin: 0 auto 3.2rem;
    color: inherit;
    font-size: var(--font-body-size);
    line-height: var(--font-body-line-height);
    opacity: 0.85;
  }

  .section-{{ section.id }} .custom-prefooter-cta__text > * {
    margin: 0;
  }

  .section-{{ section.id }} .custom-prefooter-cta__buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.6rem;
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .custom-prefooter-cta__buttons .btn {
      width: 100%;
    }
  }
{% endstyle %}

<div class="section section-{{ section.id }} section--padding custom-prefooter-cta color-{{ section.settings.color_scheme }}"{% if section.settings.css_id != blank %} id="{{ section.settings.css_id | escape }}"{% endif %}>
  <div class="section__container page-width page-width--{{ section.settings.container }}">
    <div class="custom-prefooter-cta__inner">
      {% if section.settings.heading != blank %}
        <h2 class="custom-prefooter-cta__heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="custom-prefooter-cta__text rte">{{ section.settings.text }}</div>
      {% endif %}

      {% if section.settings.button_1_label != blank or section.settings.button_2_label != blank %}
        <div class="custom-prefooter-cta__buttons">
          {% if section.settings.button_1_label != blank %}
            {% render 'button',
              button_style: section.settings.button_1_style,
              button_link: section.settings.button_1_link,
              button_label: section.settings.button_1_label,
              button_icon: section.settings.button_1_icon
            %}
          {% endif %}

          {% if section.settings.button_2_label != blank %}
            {% render 'button',
              button_style: section.settings.button_2_style,
              button_link: section.settings.button_2_link,
              button_label: section.settings.button_2_label,
              button_icon: section.settings.button_2_icon
            %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Prefooter CTA",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "fixed",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "fixed", "label": "Fixed width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-inverse"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to upgrade your tournament?"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Contact our equipment specialists to customize your glove fitting program today.</p>"
    },
    {
      "type": "range",
      "id": "text_width",
      "label": "Text width",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 560
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "First button label",
      "default": "Schedule a Consultation"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "First button link"
    },
    {
      "type": "select",
      "id": "button_1_style",
      "label": "First button style",
      "default": "btn--white",
      "options": [
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--white", "label": "White" },
        { "value": "btn--outline", "label": "Outline" },
        { "value": "btn--plain", "label": "Plain" }
      ]
    },
    {
      "type": "select",
      "id": "button_1_icon",
      "label": "First button icon",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "arrow-right", "label": "Arrow right" },
        { "value": "download", "label": "Download" }
      ]
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Second button label",
      "default": "Download Specs"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Second button link"
    },
    {
      "type": "select",
      "id": "button_2_style",
      "label": "Second button style",
      "default": "btn--outline",
      "options": [
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--white", "label": "White" },
        { "value": "btn--outline", "label": "Outline" },
        { "value": "btn--plain", "label": "Plain" }
      ]
    },
    {
      "type": "select",
      "id": "button_2_icon",
      "label": "Second button icon",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "arrow-right", "label": "Arrow right" },
        { "value": "download", "label": "Download" }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Section divider"
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "label": "Show section divider",
      "default": false
    },
    {
      "type": "select",
      "id": "divider_width",
      "label": "Divider width",
      "default": "fixed",
      "options": [
        { "value": "fixed", "label": "Fixed width" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "text",
      "id": "css_id",
      "label": "CSS ID",
      "info": "Add a unique ID for anchor links. Do not include the # symbol."
    }
  ],
  "presets": [
    {
      "name": "Custom Prefooter CTA"
    }
  ]
}
{% endschema %}
