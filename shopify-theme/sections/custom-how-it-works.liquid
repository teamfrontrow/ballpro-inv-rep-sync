{% style %}
  .section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --custom-hiw-card-background: {{ section.settings.card_background }};
    --custom-hiw-card-border: {{ section.settings.card_border }};
    --custom-hiw-image-background: {{ section.settings.image_background }};
  }

  .section-{{ section.id }} .custom-hiw__header {
    max-width: 72rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .section-{{ section.id }} .custom-hiw__heading {
    margin: 0;
    color: rgb(var(--color-text-heading));
  }

  .section-{{ section.id }} .custom-hiw__text {
    max-width: 64rem;
    margin: 1.2rem auto 0;
    color: rgba(var(--color-foreground), 0.72);
  }

  .section-{{ section.id }} .custom-hiw__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }

  .section-{{ section.id }} .custom-hiw__card {
    position: relative;
    overflow: hidden;
    min-height: 100%;
    padding: 2.4rem;
    background: var(--custom-hiw-card-background);
    border: 1px solid var(--custom-hiw-card-border);
    transition: border-color var(--duration-default), background var(--duration-default), transform var(--duration-default), box-shadow var(--duration-default);
  }

  .section-{{ section.id }} .custom-hiw__card:hover {
    transform: translateY(-0.3rem);
    border-color: rgba(var(--color-button), 0.35);
    box-shadow: 0 1.8rem 4rem rgba(var(--color-foreground), 0.08);
  }

  .section-{{ section.id }} .custom-hiw__media {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: {{ section.settings.image_ratio }};
    margin-bottom: 2.4rem;
    border-radius: var(--small-blocks-radius, 1.2rem);
    overflow: hidden;
    background: var(--custom-hiw-image-background);
  }

  .section-{{ section.id }} .custom-hiw__media img,
  .section-{{ section.id }} .custom-hiw__media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }} .custom-hiw__card-title {
    position: relative;
    z-index: 1;
    margin: 0 0 1rem;
    color: rgb(var(--color-text-heading));
  }

  .section-{{ section.id }} .custom-hiw__card-text {
    position: relative;
    z-index: 1;
    margin: 0;
    color: rgba(var(--color-foreground), 0.72);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .custom-hiw__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.4rem;
    }
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }} .custom-hiw__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }
  }
{% endstyle %}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

<div class="section section-{{ section.id }} section--padding custom-hiw color-{{ section.settings.color_scheme }}"{% if section.settings.css_id != blank %} id="{{ section.settings.css_id }}"{% endif %}>
  <div class="section__container page-width page-width--{{ section.settings.container }}">
    {% if section.settings.heading != blank or section.settings.text != blank %}
      <div class="custom-hiw__header">
        {% if section.settings.heading != blank %}
          <h2 class="custom-hiw__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="custom-hiw__text rte text-subtext">{{ section.settings.text }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="custom-hiw__grid">
      {% for block in section.blocks %}
        {% liquid
          assign image_alt = block.settings.image.alt | default: block.settings.title | escape
        %}
        <div class="custom-hiw__card blocks-radius" {{ block.shopify_attributes }}>
          <div class="custom-hiw__media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  widths: '320, 480, 640, 800, 900',
                  sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                  alt: image_alt
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class="custom-hiw__card-title {{ section.settings.card_heading_size }}">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="custom-hiw__card-text rte text-subtext">{{ block.settings.text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom How It Works",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "css_id",
      "label": "CSS ID",
      "info": "Add a unique ID to this section for anchor links (e.g. how-it-works). Do not include the # symbol."
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "fixed",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "fixed", "label": "Fixed width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Does It Work?"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Follow these four simple instructions to start seeing results in your golf marketing efforts.</p>"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ]
    },
    {
      "type": "select",
      "id": "card_heading_size",
      "label": "Card heading size",
      "default": "h5",
      "options": [
        { "value": "h4", "label": "Large" },
        { "value": "h5", "label": "Medium" },
        { "value": "h6", "label": "Small" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Image background",
      "default": "#f2f2f2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "1 / 1",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 3", "label": "Landscape" },
        { "value": "16 / 9", "label": "Wide" },
        { "value": "3 / 4", "label": "Portrait" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "label": "Show section divider",
      "default": false
    },
    {
      "type": "select",
      "id": "divider_width",
      "label": "Divider width",
      "default": "fixed",
      "options": [
        { "value": "fixed", "label": "Fixed width" },
        { "value": "full", "label": "Full width" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Select Leads"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Identify and select 10 prospective customers that represent high-value opportunities for your brand.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "Select Leads", "text": "<p>Identify and select 10 prospective customers that represent high-value opportunities for your brand.</p>" } },
        { "type": "step", "settings": { "title": "Mail Package", "text": "<p>Include a personalized matchbook tee holder, sales letter, and Top Selling products flyer in your mailing.</p>" } },
        { "type": "step", "settings": { "title": "Email Follow-up", "text": "<p>Send a brief email informing the customer you'll be calling to discuss their needs in one week.</p>" } },
        { "type": "step", "settings": { "title": "Direct Contact", "text": "<p>One week later, place the follow-up call to finalize the discussion and convert your prospect.</p>" } }
      ]
    }
  ]
}
{% endschema %}
