{%- liquid
  assign background_image = section.settings.background_image
  assign mobile_background_image = section.settings.mobile_background_image | default: background_image
  assign image_alt = section.settings.image_alt | default: section.settings.heading | escape

  assign overlay_color = section.settings.overlay_color
  if overlay_color == blank
    assign overlay_r = 0
    assign overlay_g = 0
    assign overlay_b = 0
  else
    assign overlay_r = overlay_color.red
    assign overlay_g = overlay_color.green
    assign overlay_b = overlay_color.blue
  endif

  assign overlay_strength = section.settings.gradient_strength | divided_by: 100.0
  assign overlay_midpoint = section.settings.gradient_midpoint | divided_by: 100.0
-%}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

{% style %}
  .section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --custom-landing-hero-height: {{ section.settings.height | divided_by: 10.0 }}rem;
    --custom-landing-hero-mobile-height: {{ section.settings.mobile_height | divided_by: 10.0 }}rem;
    --custom-landing-hero-content-width: {{ section.settings.content_width | divided_by: 10.0 }}rem;
  }

  .section-{{ section.id }} .custom-landing-hero__wrap {
    position: relative;
    display: flex;
    align-items: center;
    min-height: var(--custom-landing-hero-height);
    overflow: hidden;
    border-radius: var(--blocks-radius, 0);
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  .section-{{ section.id }} .custom-landing-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .section-{{ section.id }} .custom-landing-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.background_position }};
  }

  .section-{{ section.id }} .custom-landing-hero__mobile-image {
    display: none;
  }

  .section-{{ section.id }} .custom-landing-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: linear-gradient(
      to {{ section.settings.gradient_direction }},
      rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ overlay_strength }}),
      rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ overlay_midpoint }}) 55%,
      rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, 0)
    );
  }

  .section-{{ section.id }} .custom-landing-hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {% if section.settings.container == 'custom' %}{{ section.settings.container_max_width | divided_by: 10.0 }}rem{% else %}var(--page-width, 144rem){% endif %};
    margin-inline: auto;
    padding: 4.8rem var(--page-padding, 1.6rem);
  }

  .section-{{ section.id }} .custom-landing-hero__content {
    max-width: var(--custom-landing-hero-content-width);
    color: {% if section.settings.text_color == 'white' %}#ffffff{% else %}rgb(var(--color-foreground)){% endif %};
    text-align: {{ section.settings.text_alignment }};
  }

  .section-{{ section.id }} .custom-landing-hero__eyebrow {
    display: inline-block;
    margin: 0 0 2.4rem;
    padding: 0.6rem 1.2rem;
    background: rgba(var(--color-primary), 0.2);
    color: inherit;
    font-family: var(--font-subheading-family);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    border-radius: var(--badges-radius, 0);
  }

  .section-{{ section.id }} .custom-landing-hero__heading {
    margin: 0 0 2.4rem;
    color: inherit;
    letter-spacing: -0.02em;
  }

  .section-{{ section.id }} .custom-landing-hero__text {
    max-width: 64rem;
    margin: 0 0 3.2rem;
    color: inherit;
    font-size: var(--font-body-size);
    line-height: var(--font-body-line-height);
    opacity: 0.9;
  }

  .section-{{ section.id }} .custom-landing-hero__text > * {
    margin: 0;
  }

  .section-{{ section.id }} .custom-landing-hero__buttons {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  @media screen and (min-width: 640px) {
    .section-{{ section.id }} .custom-landing-hero__buttons {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .custom-landing-hero__container {
      padding-block: 6.4rem;
    }

    .section-{{ section.id }} .custom-landing-hero__heading.h1 {
      font-size: 4.9rem;
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .custom-landing-hero__wrap {
      min-height: var(--custom-landing-hero-mobile-height);
    }

    .section-{{ section.id }} .custom-landing-hero__desktop-image {
      display: {% if mobile_background_image != background_image %}none{% else %}block{% endif %};
    }

    .section-{{ section.id }} .custom-landing-hero__mobile-image {
      display: {% if mobile_background_image != background_image %}block{% else %}none{% endif %};
    }

    .section-{{ section.id }} .custom-landing-hero__buttons .btn {
      width: 100%;
    }
  }
{% endstyle %}

<div class="section section-{{ section.id }} section--padding custom-landing-hero"{% if section.settings.css_id != blank %} id="{{ section.settings.css_id | escape }}"{% endif %}>
  <div class="custom-landing-hero__wrap">
      <div class="custom-landing-hero__media" aria-hidden="true">
        {% if background_image != blank %}
          {{
            background_image
            | image_url: width: 2400
            | image_tag:
              class: 'custom-landing-hero__desktop-image',
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 2000, 2400',
              sizes: '100vw',
              alt: image_alt
          }}
        {% endif %}

        {% if mobile_background_image != blank and mobile_background_image != background_image %}
          {{
            mobile_background_image
            | image_url: width: 1200
            | image_tag:
              class: 'custom-landing-hero__mobile-image',
              loading: 'eager',
              fetchpriority: 'high',
              widths: '375, 550, 750, 1000, 1200',
              sizes: '100vw',
              alt: image_alt
          }}
        {% endif %}
      </div>

      <div class="custom-landing-hero__overlay" aria-hidden="true"></div>

      <div class="custom-landing-hero__container">
        <div class="custom-landing-hero__content">
          {% if section.settings.eyebrow != blank %}
            <div class="custom-landing-hero__eyebrow">{{ section.settings.eyebrow | escape }}</div>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h1 class="custom-landing-hero__heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h1>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="custom-landing-hero__text rte">{{ section.settings.text }}</div>
          {% endif %}

          {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
            <div class="custom-landing-hero__buttons">
              {% if section.settings.primary_button_label != blank %}
                {% render 'button',
                  button_style: section.settings.primary_button_style,
                  button_link: section.settings.primary_button_link,
                  button_label: section.settings.primary_button_label,
                  button_icon: section.settings.primary_button_icon
                %}
              {% endif %}

              {% if section.settings.secondary_button_label != blank %}
                {% render 'button',
                  button_style: section.settings.secondary_button_style,
                  button_link: section.settings.secondary_button_link,
                  button_label: section.settings.secondary_button_label,
                  button_icon: section.settings.secondary_button_icon
                %}
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

{% schema %}
{
  "name": "Custom Landing Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Content width",
      "info": "Width of the content area inside the full-bleed image.",
      "default": "theme",
      "options": [
        { "value": "theme", "label": "Theme width" },
        { "value": "custom", "label": "Custom width" }
      ]
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Custom content width",
      "info": "Used when Content width is set to Custom.",
      "min": 600,
      "max": 2000,
      "step": 20,
      "unit": "px",
      "default": 1500
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "mobile_background_image",
      "label": "Mobile background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Background image alt text"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background image position",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Gradient overlay color",
      "info": "The color the gradient fades from over the image. Leave blank to hide the overlay.",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "default": "right",
      "options": [
        { "value": "right", "label": "Left to right" },
        { "value": "left", "label": "Right to left" },
        { "value": "bottom", "label": "Top to bottom" }
      ]
    },
    {
      "type": "range",
      "id": "gradient_strength",
      "label": "Gradient strength",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "range",
      "id": "gradient_midpoint",
      "label": "Gradient midpoint strength",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Desktop height",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 420,
      "max": 760,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 420,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 680
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "default": "white",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "theme", "label": "Theme default" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "PROFESSIONAL GRADE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Golf Tournament Glove Fitting Program"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "hd1", "label": "Display" },
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Elevate your tournament with premium Cabretta leather gloves. Engineered for professional fit, durability, and a soft natural grip that elite golfers demand.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Request Information"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "select",
      "id": "primary_button_style",
      "label": "Primary button style",
      "default": "btn--primary",
      "options": [
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--white", "label": "White" },
        { "value": "btn--outline", "label": "Outline" },
        { "value": "btn--plain", "label": "Plain" }
      ]
    },
    {
      "type": "select",
      "id": "primary_button_icon",
      "label": "Primary button icon",
      "default": "arrow-right",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "arrow-right", "label": "Arrow right" },
        { "value": "download", "label": "Download" }
      ]
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "View Pricing"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "select",
      "id": "secondary_button_style",
      "label": "Secondary button style",
      "default": "btn--outline",
      "options": [
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--white", "label": "White" },
        { "value": "btn--outline", "label": "Outline" },
        { "value": "btn--plain", "label": "Plain" }
      ]
    },
    {
      "type": "select",
      "id": "secondary_button_icon",
      "label": "Secondary button icon",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "arrow-right", "label": "Arrow right" },
        { "value": "download", "label": "Download" }
      ]
    },
    {
      "type": "header",
      "content": "Section divider"
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "label": "Show section divider",
      "default": false
    },
    {
      "type": "select",
      "id": "divider_width",
      "label": "Divider width",
      "default": "fixed",
      "options": [
        { "value": "fixed", "label": "Fixed width" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "text",
      "id": "css_id",
      "label": "CSS ID",
      "info": "Add a unique ID for anchor links. Do not include the # symbol."
    }
  ],
  "presets": [
    {
      "name": "Custom Landing Hero"
    }
  ]
}
{% endschema %}
