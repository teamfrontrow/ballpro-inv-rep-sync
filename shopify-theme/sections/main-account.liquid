{{ 'customer.css' | asset_url | stylesheet_tag }}

<div
  class="customer account section section--padding"
  style="--section-padding-top: {{ section.settings.padding_top }}px;--section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <header class="customer__header flex md:flex-row flex-col justify-between items-center gap-4">
      <h1 class="customer__title h2">{{ 'customer.account.title' | t }}</h1>
      <a href="{{ routes.account_logout_url }}" class="btn btn--primary">
        <span class="btn__text">{{ 'customer.log_out' | t }}</span>
      </a>
    </header>

    <div class="account-welcome-message">
      <p>Welcome {{ customer.first_name | default: customer.name }} to your account. <a href="https://www.ballproplus.com/collections/all">Click here to view the product catalog.</a></p>
    </div>

    {%- assign is_pending = false -%}
    {%- for tag in customer.tags -%}
      {%- if tag == 'pending-approval' -%}
        {%- assign is_pending = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if is_pending -%}
      <div class="pending-approval-banner">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span>Your account is pending approval. You will receive an email once your application has been reviewed.</span>
      </div>
    {%- endif -%}

    <div class="customer__body">
      <div class="customer__sidebar flex flex-col gap-y-3">
        <div class="customer__widget blocks-radius flex flex-col gap-y-3">
          <h2 class="h5">{{ 'customer.account.details' | t }}</h2>
          {{ customer.default_address | format_address }}
          <a href="{{ routes.account_addresses_url }}" class="btn btn--underline self-start">
            {{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
          </a>
        </div>
      </div>
      <div class="customer__content">
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:general.padding.section_heading.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:general.padding.top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:general.padding.bottom.label",
      "default": 100
    }
  ]
}
{% endschema %}
