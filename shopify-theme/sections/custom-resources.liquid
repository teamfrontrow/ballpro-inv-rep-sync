{% style %}
  .section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --custom-resources-card-background: {{ section.settings.card_background }};
    --custom-resources-card-border: {{ section.settings.card_border }};
    --custom-resources-media-background: {{ section.settings.media_background }};
  }

  .section-{{ section.id }} .custom-resources__header {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    margin-bottom: 3.2rem;
  }

  .section-{{ section.id }} .custom-resources__heading {
    margin: 0;
    color: rgb(var(--color-text-heading));
  }

  .section-{{ section.id }} .custom-resources__text {
    margin: 0.8rem 0 0;
    color: rgba(var(--color-foreground), 0.72);
  }

  .section-{{ section.id }} .custom-resources__header-button {
    align-self: flex-start;
  }

  .section-{{ section.id }} .custom-resources__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }

  .section-{{ section.id }} .custom-resources__card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 2rem;
    background: var(--custom-resources-card-background);
    border: 1px solid var(--custom-resources-card-border);
    transition: transform var(--duration-default), box-shadow var(--duration-default), border-color var(--duration-default);
  }

  .section-{{ section.id }} .custom-resources__card:hover {
    transform: translateY(-0.4rem);
    border-color: rgba(var(--color-button), 0.35);
    box-shadow: 0 1.8rem 4rem rgba(var(--color-foreground), 0.1);
  }

  .section-{{ section.id }} .custom-resources__media {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 9;
    margin-bottom: 2rem;
    border-radius: var(--small-blocks-radius, 1.2rem);
    overflow: hidden;
    background: var(--custom-resources-media-background);
  }

  .section-{{ section.id }} .custom-resources__media img,
  .section-{{ section.id }} .custom-resources__media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }} .custom-resources__title {
    margin: 0 0 0.8rem;
    color: rgb(var(--color-text-heading));
  }

  .section-{{ section.id }} .custom-resources__description {
    margin: 0 0 2rem;
    color: rgba(var(--color-foreground), 0.72);
  }

  .section-{{ section.id }} .custom-resources__button-wrap {
    margin-top: auto;
  }

  .section-{{ section.id }} .custom-resources__button-wrap .btn {
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .custom-resources__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2.4rem;
      margin-bottom: 4rem;
    }

    .section-{{ section.id }} .custom-resources__header-content {
      max-width: 70rem;
    }

    .section-{{ section.id }} .custom-resources__header-button {
      flex: 0 0 auto;
    }

    .section-{{ section.id }} .custom-resources__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2.4rem;
    }
  }
{% endstyle %}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

<div class="section section-{{ section.id }} section--padding custom-resources color-{{ section.settings.color_scheme }}">
  <div class="section__container page-width page-width--{{ section.settings.container }}">
    <div class="custom-resources__header">
      <div class="custom-resources__header-content">
        {% if section.settings.heading != blank %}
          <h2 class="custom-resources__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="custom-resources__text rte text-subtext">{{ section.settings.text }}</div>
        {% endif %}
      </div>
      {% if section.settings.button_label != blank %}
        <div class="custom-resources__header-button">
          {% render 'button',
            button_style: section.settings.button_style,
            button_link: section.settings.button_link,
            button_label: section.settings.button_label,
            button_icon: section.settings.button_icon
          %}
        </div>
      {% endif %}
    </div>

    <div class="custom-resources__grid">
      {% for block in section.blocks %}
        {% liquid
          assign image_alt = block.settings.image.alt | default: block.settings.title | escape
        %}
        <div class="custom-resources__card blocks-radius" {{ block.shopify_attributes }}>
          <div class="custom-resources__media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  widths: '320, 480, 640, 800, 900',
                  sizes: '(min-width: 750px) 33vw, 100vw',
                  alt: image_alt
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class="custom-resources__title {{ section.settings.card_heading_size }}">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.description != blank %}
            <div class="custom-resources__description rte text-subtext">{{ block.settings.description }}</div>
          {% endif %}
          {% if block.settings.button_label != blank %}
            <div class="custom-resources__button-wrap">
              {% render 'button',
                button_style: block.settings.button_style,
                button_link: block.settings.button_link,
                button_label: block.settings.button_label,
                button_icon: block.settings.button_icon
              %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Resources",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "fixed",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "fixed", "label": "Fixed width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Download Resources"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Everything you need to execute your direct mail campaign.</p>"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ]
    },
    {
      "type": "select",
      "id": "card_heading_size",
      "label": "Card heading size",
      "default": "h5",
      "options": [
        { "value": "h4", "label": "Large" },
        { "value": "h5", "label": "Medium" },
        { "value": "h6", "label": "Small" }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Header button label",
      "default": "View All Resources"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Header button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Header button style",
      "default": "btn--plain",
      "options": [
        { "value": "btn--plain", "label": "Plain" },
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--outline", "label": "Outline" }
      ]
    },
    {
      "type": "select",
      "id": "button_icon",
      "label": "Header button icon",
      "default": "arrow-right",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "arrow-right", "label": "Arrow right" },
        { "value": "download", "label": "Download" }
      ]
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "media_background",
      "label": "Media background",
      "default": "#f2f2f2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "label": "Show section divider",
      "default": false
    },
    {
      "type": "select",
      "id": "divider_width",
      "label": "Divider width",
      "default": "fixed",
      "options": [
        { "value": "fixed", "label": "Fixed width" },
        { "value": "full", "label": "Full width" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Sample Sales Letter"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>A pre-written template designed to convert prospects. Just add your details.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Download Google Doc"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "default": "btn--outline",
          "options": [
            { "value": "btn--primary", "label": "Primary" },
            { "value": "btn--secondary", "label": "Secondary" },
            { "value": "btn--white", "label": "White" },
            { "value": "btn--outline", "label": "Outline" }
          ]
        },
        {
          "type": "select",
          "id": "button_icon",
          "label": "Button icon",
          "default": "download",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "arrow-right", "label": "Arrow right" },
            { "value": "download", "label": "Download" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Resources",
      "blocks": [
        { "type": "resource", "settings": { "title": "Sample Sales Letter", "description": "<p>A pre-written template designed to convert prospects. Just add your details.</p>", "button_label": "Download Google Doc" } },
        { "type": "resource", "settings": { "title": "Top Sellers Sheet", "description": "<p>Showcase our highest performing golf products to your new clients.</p>", "button_label": "Download PDF" } },
        { "type": "resource", "settings": { "title": "Matchbook Template", "description": "<p>Precise design templates for preparing your brand's artwork.</p>", "button_label": "Download Template" } }
      ]
    }
  ]
}
{% endschema %}
