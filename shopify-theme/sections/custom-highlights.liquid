{% style %}
  .section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --custom-highlights-divider-color: {{ section.settings.divider_color }};
    --custom-highlights-card-background: {{ section.settings.card_background }};
    --custom-highlights-card-border: {{ section.settings.card_border }};
    --custom-highlights-card-heading-color: {{ section.settings.card_heading_color }};
    --custom-highlights-card-text-color: {{ section.settings.card_text_color }};
    --custom-highlights-icon-background: {{ section.settings.icon_background }};
    --custom-highlights-icon-color: {{ section.settings.icon_color }};
    --custom-highlights-card-radius: {{ section.settings.card_radius | divided_by: 10.0 }}rem;
    --custom-highlights-card-padding: {{ section.settings.card_padding | divided_by: 10.0 }}rem;
  }

  .section-{{ section.id }} .custom-highlights__header {
    max-width: 72rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .section-{{ section.id }} .custom-highlights__heading {
    margin: 0;
    color: rgb(var(--color-text-heading));
  }

  .section-{{ section.id }} .custom-highlights__divider {
    width: 8rem;
    height: 0.6rem;
    margin: 1.6rem auto 0;
    background: var(--custom-highlights-divider-color);
  }

  .section-{{ section.id }} .custom-highlights__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }

  .section-{{ section.id }} .custom-highlights__card {
    min-height: 100%;
    padding: var(--custom-highlights-card-padding);
    background: var(--custom-highlights-card-background);
    border: 1px solid var(--custom-highlights-card-border);
    border-radius: var(--custom-highlights-card-radius);
    transition: transform var(--duration-default), box-shadow var(--duration-default);
  }

  .section-{{ section.id }} .custom-highlights__card:hover {
    transform: translateY(-0.3rem);
    box-shadow: 0 1.8rem 4rem rgba(var(--color-foreground), 0.08);
  }

  .section-{{ section.id }} .custom-highlights__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 6.4rem;
    height: 6.4rem;
    margin-bottom: 2.4rem;
    color: var(--custom-highlights-icon-color);
    background: var(--custom-highlights-icon-background);
    border-radius: 999px;
    transition: transform var(--duration-default);
  }

  .section-{{ section.id }} .custom-highlights__card:hover .custom-highlights__icon {
    transform: scale(1.1);
  }

  .section-{{ section.id }} .custom-highlights__icon svg {
    display: block;
    width: 3.6rem;
    height: 3.6rem;
  }

  .section-{{ section.id }} .custom-highlights__card-title {
    margin: 0 0 1.2rem;
    color: var(--custom-highlights-card-heading-color);
  }

  .section-{{ section.id }} .custom-highlights__card-text,
  .section-{{ section.id }} .custom-highlights__card-text p {
    color: var(--custom-highlights-card-text-color);
  }

  .section-{{ section.id }} .custom-highlights__card-text p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .custom-highlights__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }} .custom-highlights__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }
  }
{% endstyle %}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

<div class="section section-{{ section.id }} section--padding custom-highlights color-{{ section.settings.color_scheme }}"{% if section.settings.css_id != blank %} id="{{ section.settings.css_id | escape }}"{% endif %}>
  <div class="section__container page-width page-width--{{ section.settings.container }}">
    {% if section.settings.heading != blank %}
      <div class="custom-highlights__header">
        <h2 class="custom-highlights__heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
        {% if section.settings.show_heading_divider %}
          <div class="custom-highlights__divider"></div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="custom-highlights__grid">
        {% for block in section.blocks %}
          <div class="custom-highlights__card" {{ block.shopify_attributes }}>
            <div class="custom-highlights__icon" aria-hidden="true">
              {% case block.settings.icon %}
                {% when 'verified' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.5l2 2 4.5-5"></path><path d="M12 2.75l2.6 1.75 3.1-.15 1.05 2.9 2.45 1.9-.8 3.05.8 3.05-2.45 1.9-1.05 2.9-3.1-.15L12 21.25 9.4 19.5l-3.1.15-1.05-2.9-2.45-1.9.8-3.05-.8-3.05 2.45-1.9 1.05-2.9 3.1.15L12 2.75z"></path></svg>
                {% when 'celebration' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20l4.2-12.6L16.6 15.8 4 20z"></path><path d="M8.2 7.4l8.4 8.4"></path><path d="M14 5.5l1-2"></path><path d="M18.5 9l2.2-.8"></path><path d="M17.4 3.6l.7-1.6"></path><path d="M21.3 13.4l1.7.5"></path><path d="M11.3 4.8c.8-1.4 2.7-1.4 3.5 0"></path></svg>
                {% else %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6.5h11v9H3z"></path><path d="M14 9h3.2l3.8 4v2.5h-7z"></path><path d="M6.5 18.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path><path d="M17.5 18.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path><path d="M8.5 16.5h7"></path></svg>
              {% endcase %}
            </div>

            {% if block.settings.title != blank %}
              <h3 class="custom-highlights__card-title {{ section.settings.card_heading_size }}">{{ block.settings.title | escape }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="custom-highlights__card-text rte text-subtext">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Highlights",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "fixed",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "fixed", "label": "Fixed width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Program Highlights"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_heading_divider",
      "label": "Show heading divider",
      "default": true
    },
    {
      "type": "select",
      "id": "card_heading_size",
      "label": "Card heading size",
      "default": "h5",
      "options": [
        { "value": "h4", "label": "Large" },
        { "value": "h5", "label": "Medium" },
        { "value": "h6", "label": "Small" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Heading divider color",
      "default": "#1D349A"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#E7EEF5"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#C0C9C1"
    },
    {
      "type": "color",
      "id": "card_heading_color",
      "label": "Card heading color",
      "default": "#191C1A"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#404943"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#1D349A"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "label": "Show section divider",
      "default": false
    },
    {
      "type": "select",
      "id": "divider_width",
      "label": "Divider width",
      "default": "fixed",
      "options": [
        { "value": "fixed", "label": "Fixed width" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "text",
      "id": "css_id",
      "label": "CSS ID",
      "info": "Add a unique ID for anchor links. Do not include the # symbol."
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "local_shipping",
          "options": [
            { "value": "local_shipping", "label": "Shipping truck" },
            { "value": "verified", "label": "Verified badge" },
            { "value": "celebration", "label": "Celebration" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Extra Gloves Shipped"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Program ships 20% extra gloves to your event, ensuring everyone gets the right fit without stockouts.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Highlights",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "icon": "local_shipping",
            "title": "Extra Gloves Shipped",
            "text": "<p>Program ships 20% extra gloves to your event, ensuring everyone gets the right fit without stockouts.</p>"
          }
        },
        {
          "type": "highlight",
          "settings": {
            "icon": "verified",
            "title": "Quality Glove",
            "text": "<p>Premium Cabretta leather offering an exceptional soft natural grip and unparalleled breathability.</p>"
          }
        },
        {
          "type": "highlight",
          "settings": {
            "icon": "celebration",
            "title": "Enhances Experience",
            "text": "<p>The blueprint for a successful event starts with giving the golfers memorable, high-performance keepsakes.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
