            {
              "value": "italic",
              "label": "Italic"
            },
            {
              "value": "normal",
              "label": "Normal"
            }
          ],
          "default": "italic"
        },
        {
          "type": "color",
          "id": "highlight_style_color",
          "label": "Highlight style color"
        },
        {
          "type": "color",
          "id": "highlight_text_color",
          "label": "Highlight text color"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            {
              "value": "h5",
              "label": "H5"
            },
            {
              "value": "h4",
              "label": "H4"
            },
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h2",
              "label": "H2"
            },
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "hd2",
              "label": "HD2"
            },
            {
              "value": "hd1",
              "label": "HD1"
            }
          ],
          "default": "h2"
        }
      ]
