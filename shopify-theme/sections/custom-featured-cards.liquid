{%- liquid
  assign header_alignment = section.settings.section_header_alignment
  assign header_alignment_mobile = section.settings.section_header_alignment_mobile
  if header_alignment_mobile == 'inherit'
    assign header_alignment_mobile = header_alignment
  endif

  assign column_gap = '2.4rem'
  case section.settings.column_gap
    when 'none'
      assign column_gap = '0rem'
    when '2xs'
      assign column_gap = '0.4rem'
    when 'extra-small'
      assign column_gap = '0.8rem'
    when 'small'
      assign column_gap = '1.2rem'
    when 'medium'
      assign column_gap = '1.6rem'
    when 'large'
      assign column_gap = '2.4rem'
    when 'extra-large'
      assign column_gap = '3.2rem'
  endcase

  assign row_gap = column_gap
  case section.settings.row_gap
    when 'inherit'
      assign row_gap = column_gap
    when 'none'
      assign row_gap = '0rem'
    when '2xs'
      assign row_gap = '0.4rem'
    when 'extra-small'
      assign row_gap = '0.8rem'
    when 'small'
      assign row_gap = '1.2rem'
    when 'medium'
      assign row_gap = '1.6rem'
    when 'large'
      assign row_gap = '2.4rem'
    when 'extra-large'
      assign row_gap = '3.2rem'
  endcase

  assign overlay_opacity = section.settings.card_overlay_opacity | divided_by: 100.0
  assign overlay_color = section.settings.card_overlay_color | color_modify: 'alpha', overlay_opacity
  assign remaining_blocks = section.blocks.size | minus: 1
  assign trailing_row_count = remaining_blocks | modulo: 4
  if remaining_blocks > 0 and trailing_row_count == 0
    assign trailing_row_count = 4
  endif
-%}

{% style %}
  .section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --featured-cards-column-gap: {{ column_gap }};
    --featured-cards-row-gap: {{ row_gap }};
    --featured-cards-overlay: {{ overlay_color }};
    --featured-cards-text: {{ section.settings.card_text_color }};
  }

  .section-{{ section.id }} .featured-cards__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--featured-cards-row-gap);
  }

  .section-{{ section.id }} .featured-cards__item {
    min-width: 0;
  }

  .section-{{ section.id }} .featured-cards__card {
    position: relative;
    overflow: hidden;
    min-height: clamp(24rem, 36vw, 32rem);
    background: rgb(var(--color-foreground), 0.08);
  }

  .section-{{ section.id }} .featured-cards__item--hero .featured-cards__card {
    min-height: clamp(34rem, 50vw, 54rem);
  }

  .section-{{ section.id }} .featured-cards__media,
  .section-{{ section.id }} .featured-cards__media picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .section-{{ section.id }} .featured-cards__media img,
  .section-{{ section.id }} .featured-cards__media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }} .featured-cards__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.08) 0%, var(--featured-cards-overlay) 100%);
  }

  .section-{{ section.id }} .featured-cards__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: inherit;
    padding: 2rem;
    color: var(--featured-cards-text);
  }

  .section-{{ section.id }} .featured-cards__item--hero .featured-cards__body {
    padding: 2.4rem;
  }

  .section-{{ section.id }} .featured-cards__body--middle {
    justify-content: center;
  }

  .section-{{ section.id }} .featured-cards__body--left {
    align-items: flex-start;
    text-align: left;
  }

  .section-{{ section.id }} .featured-cards__body--center {
    align-items: center;
    text-align: center;
  }

  .section-{{ section.id }} .featured-cards__body--right {
    align-items: flex-end;
    text-align: right;
  }

  .section-{{ section.id }} .featured-cards__top,
  .section-{{ section.id }} .featured-cards__bottom {
    width: 100%;
  }

  .section-{{ section.id }} .featured-cards__content {
    display: inline-flex;
    flex-direction: column;
    gap: 1rem;
    max-width: min(100%, 54rem);
    margin-top: auto;
  }

  .section-{{ section.id }} .featured-cards__body--middle .featured-cards__content {
    margin-top: 0;
  }

  .section-{{ section.id }} .featured-cards__item--hero .featured-cards__content {
    max-width: min(100%, 60rem);
    padding: 2.2rem;
  }

  .section-{{ section.id }} .featured-cards__title {
    margin: 0;
    color: inherit;
  }

  .section-{{ section.id }} .featured-cards__text,
  .section-{{ section.id }} .featured-cards__text > * {
    color: inherit;
  }

  .section-{{ section.id }} .featured-cards__text > *:first-child {
    margin-top: 0;
  }

  .section-{{ section.id }} .featured-cards__text > *:last-child {
    margin-bottom: 0;
  }

  .section-{{ section.id }} .featured-cards__button {
    margin-top: 0.4rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .featured-cards__grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      column-gap: var(--featured-cards-column-gap);
      row-gap: var(--featured-cards-row-gap);
    }

    .section-{{ section.id }} .featured-cards__item--hero,
    .section-{{ section.id }} .featured-cards__item--full {
      grid-column: 1 / -1;
    }

    .section-{{ section.id }} .featured-cards__item--half {
      grid-column: span 6;
    }

    .section-{{ section.id }} .featured-cards__item--third {
      grid-column: span 4;
    }

    .section-{{ section.id }} .featured-cards__item--quarter {
      grid-column: span 3;
    }

    .section-{{ section.id }} .featured-cards__body {
      padding: 2.4rem;
    }
  }
{% endstyle %}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}
<div class="section section-{{ section.id }} section--padding featured-cards color-{{ section.settings.color_scheme }}">
  <div class="section__container page-width page-width--{{ section.settings.container }}">
    {% render 'section-heading',
      section_settings: section.settings,
      button_label: section.settings.button_label,
      button_link: section.settings.button_link,
      button_style: section.settings.button_style,
      button_icon: section.settings.button_icon,
      button_visible: true,
      header_alignment: header_alignment,
      header_alignment_mobile: header_alignment_mobile
    %}

    {% if section.blocks.size > 0 %}
      <div class="featured-cards__grid">
        {%- for block in section.blocks -%}
          {%- liquid
            assign item_class = 'featured-cards__item'
            if forloop.first
              assign item_class = item_class | append: ' featured-cards__item--hero'
            else
              assign regular_index = forloop.index0 | minus: 1
              assign items_left_including_current = remaining_blocks | minus: regular_index
              if items_left_including_current <= trailing_row_count
                case trailing_row_count
                  when 1
                    assign item_class = item_class | append: ' featured-cards__item--full'
                  when 2
                    assign item_class = item_class | append: ' featured-cards__item--half'
                  when 3
                    assign item_class = item_class | append: ' featured-cards__item--third'
                  else
                    assign item_class = item_class | append: ' featured-cards__item--quarter'
                endcase
              else
                assign item_class = item_class | append: ' featured-cards__item--quarter'
              endif
            endif

            assign body_alignment_class = 'featured-cards__body--' | append: block.settings.content_alignment
            if block.settings.content_position == 'middle'
              assign body_alignment_class = body_alignment_class | append: ' featured-cards__body--middle'
            endif

            assign card_ratio = '1 / 1'
            case section.settings.image_ratio
              when 'adapt'
                if block.settings.image != blank
                  assign card_ratio = block.settings.image.aspect_ratio
                endif
              when 'portrait'
                assign card_ratio = '4 / 5'
              when 'square'
                assign card_ratio = '1 / 1'
              when 'landscape'
                assign card_ratio = '4 / 3'
              when 'wide'
                assign card_ratio = '16 / 9'
            endcase

            assign alt = block.settings.image.alt | default: block.settings.title | escape
          -%}
          <div class="{{ item_class }}" {{ block.shopify_attributes }}>
            <article class="featured-cards__card blocks-radius">
              <div class="featured-cards__media hover-wrapper">
                <motion-element class="block w-full h-full" data-motion="zoom-out-sm">
                  <picture style="display:block; aspect-ratio: {{ card_ratio }};">
                    {%- if block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 1800
                        | image_tag:
                          loading: 'lazy',
                          class: 'motion-reduce absolute inset-0 w-full h-full hover-scale-up',
                          widths: '375, 550, 750, 1100, 1500, 1800',
                          sizes: '(min-width: 1200px) 1200px, 100vw',
                          is: 'image-lazy',
                          alt: alt
                      }}
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </picture>
                </motion-element>
              </div>

              <div class="featured-cards__body {{ body_alignment_class }}">
                <div class="featured-cards__content">
                  {%- if block.settings.title != blank -%}
                    <h3 class="featured-cards__title {{ block.settings.heading_size }}">
                      {% render 'highlight-text',
                        hl_text: block.settings.title,
                        hl_style: block.settings.highlight_style,
                        hl_font_style: block.settings.highlight_font_style,
                        hl_style_color: block.settings.highlight_style_color,
                        hl_text_color: block.settings.highlight_text_color
                      %}
                    </h3>
                  {%- endif -%}

                  {%- if block.settings.text != blank -%}
                    <div class="featured-cards__text rte {{ block.settings.text_size }}">
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}

                  {%- if block.settings.button_label != blank -%}
                    <div class="featured-cards__button">
                      {% render 'button',
                        button_style: block.settings.button_style,
                        button_link: block.settings.button_link,
                        button_label: block.settings.button_label,
                        button_icon: block.settings.button_icon
                      %}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </article>
          </div>
        {%- endfor -%}
      </div>
    {% endif %}
  </div>
</div>

