# Public origin of this connector, including https:// in production.
APP_URL=http://localhost:3000

# The single client store this deployment is allowed to connect to.
SHOPIFY_SHOP_DOMAIN=ballproplusdev.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,write_products
SHOPIFY_API_VERSION=2026-07

# Optional compatibility path for an existing admin-created custom app token.
SHOPIFY_ADMIN_TOKEN=

# 32-byte key encoded as 64 hexadecimal characters for stored token encryption.
TOKEN_ENCRYPTION_KEY=

CONNECTOR_DATABASE_URL=postgresql://ballpro:ballpro@localhost:5432/ballpro_connector
REPSPARK_DATABASE_URL=

# Used by docker-compose.yml for the connector-db service and internal URL.
POSTGRES_PASSWORD=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SYNC_DEFAULT_CAP=500
FUTURE_HORIZON_DAYS=365
LOG_LEVEL=info
